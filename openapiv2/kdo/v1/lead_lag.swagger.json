        "tickChange": {
          "type": "string",
          "format": "int64",
          "title": "틱 변동량"
        },
        "futuresSide": {
          "type": "string",
          "title": "선물 주문 방향 (BID/ASK)"
        },
        "etfSide": {
          "type": "string",
          "title": "ETF 주문 방향 (BID/ASK)"
        },
        "futuresPrice": {
          "type": "number",
          "format": "double",
          "title": "선물 주문 가격"
        },
        "etfPrice": {
          "type": "number",
          "format": "double",
          "title": "ETF 주문 가격"
        },
        "futuresQty": {
          "type": "string",
          "format": "int64",
          "title": "선물 주문 수량"
        },
        "etfQty": {
          "type": "string",
          "format": "int64",
          "title": "ETF 주문 수량"
        }
      },
      "title": "시그널 상세 정보"
    },
    "lead_lagLeadLagState": {
      "type": "string",
      "enum": [
        "LEAD_LAG_STATE_UNSPECIFIED",
        "LEAD_LAG_STATE_IDLE",
        "LEAD_LAG_STATE_MONITORING",
        "LEAD_LAG_STATE_TRIGGERED",
        "LEAD_LAG_STATE_ERROR"
      ],
      "default": "LEAD_LAG_STATE_UNSPECIFIED",
      "title": "LeadLag 서비스 실행 상태"
    },
    "lead_lagLeadLagStatusUpdate": {
      "type": "object",
      "properties": {
        "leadLagId": {
          "type": "integer",
          "format": "int32",
          "title": "전략 ID"
        },
        "state": {
          "$ref": "#/definitions/lead_lagLeadLagState",
          "title": "서비스 실행 상태 (변경 시에만 전송)"
        },
        "futuresPosition": {
          "type": "string",
          "format": "int64",
          "title": "현재 선물 포지션 (양수=롱, 음수=숏)"
        },
        "totalTrades": {
          "type": "string",
          "format": "uint64",
          "title": "총 트레이드 수"
        },
        "lastFuturesPrice": {
          "type": "number",
          "format": "double",
          "title": "마지막 선물 mid price"
        },
        "lastSignal": {
          "$ref": "#/definitions/lead_lagLeadLagSignalInfo",
          "title": "마지막 시그널 정보 (변경 시에만 전송)"
        },
        "priceBuffer": {
          "$ref": "#/definitions/lead_lagLeadLagPriceBufferInfo",
          "title": "Price buffer 상태"
        },
        "latencyUs": {
          "type": "string",
          "format": "uint64",
          "title": "주문 실행 지연시간 (마이크로초)"
        },
        "timestampUs": {
          "type": "string",
          "format": "uint64",
          "title": "타임스탬프 (마이크로초)"
        }
      },
      "title": "LeadLag 실시간 상태 업데이트 (delta 방식: 변경된 필드만 전송)"
    },
    "lead_lagLeadLagTriggerConfig": {
      "type": "object",
      "properties": {
        "tickThreshold": {
          "type": "string",
          "format": "int64",
          "title": "트리거 틱 수 (선물 가격 변동 임계값, 틱 단위)"
        },
        "windowMs": {
          "type": "string",
          "format": "uint64",
          "title": "감지 윈도우 (밀리초)"
        },
        "cooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "트리거 후 재트리거까지 대기시간 (밀리초)"
        },
        "maxPosition": {
          "type": "string",
          "format": "int64",
          "title": "최대 동시 포지션 (선물 계약 수)"
        },
        "etfHedgeQuantity": {
          "type": "string",
          "format": "int64",
          "title": "선물 1계약당 ETF 헷지 수량"
        },
        "futuresOrderQuantity": {
          "type": "string",
          "format": "int64",
          "title": "선물 주문 수량 (계약 수)"
        }
      },
      "title": "선물 급변 감지 설정"
    },
    "lead_lagListLeadLagsResponse": {
      "type": "object",
      "properties": {
        "leadLags": {
          "type": "array",
          "items": {
