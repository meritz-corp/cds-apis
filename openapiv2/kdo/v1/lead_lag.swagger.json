          "title": "활성화 여부"
        },
        "futuresTickSize": {
          "type": "number",
          "format": "double",
          "title": "선물 틱 사이즈 (예: 0.05)"
        },
        "futuresMultiplier": {
          "type": "number",
          "format": "double",
          "title": "선물 승수 (예: 250000)"
        },
        "createTime": {
          "type": "string",
          "format": "date-time",
          "title": "생성 시간",
          "readOnly": true
        },
        "updateTime": {
          "type": "string",
          "format": "date-time",
          "title": "수정 시간",
          "readOnly": true
        }
      },
      "title": "선물-ETF 선행 차익거래 설정",
      "required": [
