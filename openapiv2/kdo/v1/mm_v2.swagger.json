    "commonPdfDecomposeHedgePricing": {
      "type": "object",
      "description": "PDF 재귀 분해 헷지 가격 산출 (파라미터 없음)\nNAV 계산은 Etf.decomposed_constituents를 PdfNavHedge와 동일 공식으로 적용."
    },
    "commonPdfNavHedgePricing": {
      "type": "object",
      "title": "분해 헷지 가격 산출 (추가 파라미터 없음)"
    },
    "mm_v2EtfMmV2": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ETF 심볼"
        },
        "fundCode": {
          "type": "string",
          "title": "Fund"
        },
        "askBasis": {
          "type": "number",
          "format": "double",
          "title": "매도 basis 스프레드"
        },
        "bidBasis": {
          "type": "number",
          "format": "double",
          "title": "매수 basis 스프레드"
        },
        "depth": {
          "type": "integer",
          "format": "int64",
          "title": "호가 깊이 (양방향 레벨 수)"
        },
        "tickSize": {
          "type": "string",
          "format": "int64",
          "title": "ETF tick 크기 (원 단위, i64)"
        },
        "offset": {
          "$ref": "#/definitions/mm_v2EtfMmV2Offset",
          "title": "동적 offset 조정 설정"
        },
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "pricingMethod": {
          "$ref": "#/definitions/commonEtfPricing",
          "title": "ETF 가격 산출 방식"
        },
        "bidAdjustment": {
          "type": "number",
          "format": "double",
          "title": "매수 호가 조정값"
        },
        "askAdjustment": {
          "type": "number",
          "format": "double",
          "title": "매도 호가 조정값"
        },
        "bidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매수 주문 수량 (i64)"
        },
        "askQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매도 주문 수량 (i64)"
        },
        "momentumEnabled": {
          "type": "boolean",
          "title": "모멘텀 활성화 여부"
        },
        "momentumWindow": {
          "type": "integer",
          "format": "int64",
          "title": "모멘텀 윈도우 크기"
        },
        "momentumSensitivity": {
          "type": "number",
          "format": "double",
          "title": "모멘텀 민감도"
        },
        "quantityLimit": {
          "$ref": "#/definitions/mm_v2EtfMmV2QuantityLimit",
          "title": "매수/매도 수량 한도"
        },
        "precomputePolicy": {
          "$ref": "#/definitions/v1mm_v2PrecomputePolicy",
          "title": "precomputed quote retreat 처리 정책"
        },
        "pricingSourceLiquidityImbalanceGuardEnabled": {
          "type": "boolean",
          "title": "pricing source 선물 1호가 잔량 imbalance guard 활성화 여부"
        },
        "momentumDeadbandTicks": {
          "type": "integer",
          "format": "int32",
          "description": "모멘텀 활성 판정 deadband (틱 수).\n|bid_adj| 또는 |ask_adj|가 이 틱 수 이상이어야 Momentum 모드로 진입.\n0이면 모멘텀 enabled만으로 활성 판정."
        },
        "exposureSkewEnabled": {
          "type": "boolean",
          "title": "ExposureSkew 활성화 여부 (MM v2 모드 2: 누적 노출 균형)"
        },
        "exposureSkewTriggerQuantity": {
          "type": "string",
          "format": "int64",
          "title": "ExposureSkew 활성화 임계값 (순포지션 절댓값이 이 값 이상이면 skew 활성화)"
        },
        "exposureSkewLimitQuantity": {
          "type": "string",
          "format": "int64",
          "title": "ExposureSkew 포화 임계값 (순포지션 절댓값이 이 값에 도달하면 max_skew_ticks 적용)"
        },
        "exposureSkewMaxSkewTicks": {
          "type": "integer",
          "format": "int32",
          "title": "ExposureSkew 최대 틱 수 (양방향 호가 평행이동 상한)"
        }
      },
      "description": "ETF MM v2 설정\nLP 대비 차이: hedge 필드 없음, position_adjustment 없음, ExposureSkew + momentum_deadband_ticks 추가."
