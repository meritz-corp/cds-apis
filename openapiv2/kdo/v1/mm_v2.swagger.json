  "paths": {
    "/v1/mm_v2": {
      "get": {
        "summary": "ETF MM v2 목록 조회",
        "operationId": "MmV2Service_ListEtfMmV2s",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mm_v2ListEtfMmV2sResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "Available Sequence and Operator\n* etf_symbol\n  * `equal`, `contains`\n* fund_code\n  * `equal`, `contains`",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "MmV2Service"
        ]
      }
    },
    "/v1/mm_v2/etfs/*/funds/*/status": {
      "get": {
        "summary": "ETF MM v2 상태 목록 조회",
