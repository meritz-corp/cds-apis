            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "Available Sequence and Operator\n* etf_symbol: `equal`, `contains`\n* fund_code: `equal`, `contains`\n* state: `equal`\n* fill_statistics.buy_filled_quantity: `greater_than`, `less_than`",
