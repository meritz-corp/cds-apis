            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "Supported Fields: \"fill_statistics.buy_filled_quantity\", \"fill_statistics.sell_filled_quantity\"",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "MmV2Service"
        ]
      }
    },
    "/v1/mm_v2/etfs/{symbol}/funds/{fundCode}": {
      "patch": {
        "summary": "ETF MM v2 업데이트",
        "operationId": "MmV2Service_UpdateEtfMmV2",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mm_v2EtfMmV2"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ETF 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "fundCode",
            "description": "펀드 코드",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "depth": {
                  "type": "integer",
                  "format": "int64",
                  "title": "호가 깊이"
                },
                "offset": {
                  "$ref": "#/definitions/mm_v2EtfMmV2Offset",
                  "title": "동적 offset 조정 설정"
                },
                "askBasis": {
                  "type": "number",
                  "format": "double"
                },
                "bidBasis": {
                  "type": "number",
                  "format": "double"
                },
                "bidQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "매수 주문 수량"
                },
                "askQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "매도 주문 수량"
                },
                "bidAdjustment": {
                  "type": "number",
                  "format": "double",
                  "title": "매수 호가 조정값"
                },
                "askAdjustment": {
                  "type": "number",
                  "format": "double",
                  "title": "매도 호가 조정값"
                },
                "momentumEnabled": {
                  "type": "boolean",
                  "title": "모멘텀 활성화 여부"
                },
                "momentumWindow": {
                  "type": "integer",
                  "format": "int64",
                  "title": "모멘텀 윈도우 크기"
                },
                "momentumSensitivity": {
                  "type": "number",
                  "format": "double",
                  "title": "모멘텀 민감도"
                },
                "quantityLimit": {
                  "$ref": "#/definitions/mm_v2EtfMmV2QuantityLimit",
                  "title": "매수/매도 수량 한도"
                },
                "precomputePolicy": {
                  "$ref": "#/definitions/v1mm_v2PrecomputePolicy",
                  "title": "precomputed quote retreat 처리 정책"
                },
                "pricingSourceLiquidityImbalanceGuardEnabled": {
                  "type": "boolean",
                  "title": "pricing source 선물 1호가 잔량 imbalance guard 활성화 여부"
                },
                "momentumDeadbandTicks": {
                  "type": "integer",
                  "format": "int32",
                  "title": "모멘텀 deadband 틱 수"
                },
                "exposureSkew": {
                  "$ref": "#/definitions/mm_v2UpdateEtfMmV2ExposureSkewFields",
                  "title": "ExposureSkew 설정 업데이트"
                }
              },
              "title": "UpdateEtfMmV2"
            }
          }
        ],
        "tags": [
          "MmV2Service"
        ]
      }
    },
