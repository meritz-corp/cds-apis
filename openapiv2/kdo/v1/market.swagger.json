  "paths": {
    "/v1/market/raw-messages/sockets": {
      "post": {
        "summary": "새로운 Raw 메시지 스트리밍 UDP 소켓 추가",
        "operationId": "MarketService_AddRawMessagesSocket",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/marketAddRawMessagesSocketResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/marketAddRawMessagesSocketRequest"
            }
          }
        ],
        "tags": [
          "MarketService"
        ]
      }
    },
    "/v1/market/raw-messages:stream": {
      "get": {
        "summary": "Raw 메시지 스트리밍 (server-side streaming)",
        "operationId": "MarketService_StreamRawMessages",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/marketRawMarketMessage"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of marketRawMarketMessage"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "socketIds",
            "description": "Optional filter by socket IDs (empty = all sockets)",
            "in": "query",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "bufferSize",
            "description": "Optional buffer size for the stream (default: 100)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          }
        ],
        "tags": [
          "MarketService"
        ]
      }
    },
