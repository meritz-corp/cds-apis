                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "수정 시간",
                  "readOnly": true
                }
              },
              "title": "수정할 바스켓",
              "required": [
                "basketType"
              ]
            }
          },
          {
            "name": "updateMask",
            "description": "수정할 필드 마스크",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "BasketService"
        ]
      }
    },
