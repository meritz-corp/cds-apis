    "basketBasketItemValue": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "종목 심볼"
        },
        "quantity": {
          "type": "string",
          "format": "int64",
          "title": "수량"
        },
        "price": {
          "type": "string",
          "title": "사용된 가격"
        },
