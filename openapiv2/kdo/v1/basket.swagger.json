            }
          }
        },
        "parameters": [
          {
            "name": "basket",
            "description": "생성할 바스켓",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/basketBasket",
              "required": [
                "basket"
              ]
            }
          }
        ],
        "tags": [
          "BasketService"
        ]
      }
    },
