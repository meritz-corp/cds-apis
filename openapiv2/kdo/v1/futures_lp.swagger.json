        "parameters": [
          {
            "name": "futureSymbol",
            "description": "선물 종목 심볼 (예: \"101S6\")",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "fundCode",
            "description": "펀드 코드",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "FuturesLpService"
        ]
      },
      "patch": {
        "summary": "선물 LP 설정 업데이트",
        "operationId": "FuturesLpService_UpdateFuturesLp",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/futures_lpFuturesLp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "futureSymbol",
            "description": "선물 종목 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "fundCode",
            "description": "펀드 코드",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "bidQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "매수 주문 수량"
                },
                "askQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "매도 주문 수량"
                },
                "bidAdjustment": {
                  "type": "number",
                  "format": "double",
                  "title": "매수 호가 조정값"
                },
                "askAdjustment": {
                  "type": "number",
                  "format": "double",
                  "title": "매도 호가 조정값"
                },
                "bidBasis": {
                  "type": "number",
                  "format": "double",
                  "title": "LP 마진 — bid spread"
                },
                "askBasis": {
                  "type": "number",
                  "format": "double",
                  "title": "LP 마진 — ask spread"
                },
                "depth": {
                  "type": "integer",
                  "format": "int64",
                  "title": "호가 깊이"
                },
                "offset": {
                  "$ref": "#/definitions/lpEtfLpOffset",
                  "title": "자동 offset 조정 설정"
                },
                "quantityLimit": {
                  "$ref": "#/definitions/futures_lpFuturesLpQuantityLimit",
                  "title": "매수/매도 수량 한도"
                },
                "etfPricing": {
                  "type": "string",
                  "title": "EtfPricing variant 이름 (변경 시에만 Some, 예: \"pdf_nav_hedge\", \"leverage_future\")"
                }
              },
              "title": "UpdateFuturesLp"
            }
          }
        ],
        "tags": [
          "FuturesLpService"
        ]
      }
    },
