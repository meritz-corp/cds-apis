  "paths": {
    "/v1/futures/lp": {
      "get": {
        "summary": "선물 LP 목록 조회",
        "operationId": "FuturesLpService_ListFuturesLps",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/futures_lpListFuturesLpsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "필터 조건\n\nAvailable Fields and Operators\n* future_symbol\n  * `equal`, `contains`\n* fund_code\n  * `equal`, `contains`\n\nExamples\n* filter=future_symbol:\"101S6\"\n* filter=fund_code=\"0331\"",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "FuturesLpService"
        ]
      }
    },
    "/v1/futures/lp/status": {
      "get": {
        "summary": "선물 LP 상태 목록 조회",
        "operationId": "FuturesLpService_ListFuturesLpStatuses",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/futures_lpListFuturesLpStatusesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "필터 조건\n\nAvailable Fields and Operators\n* future_symbol\n  * `equal`, `contains`\n* fund_code\n  * `equal`, `contains`\n* state\n  * `equal`\n* fill_statistics.buy_filled_quantity\n  * `greater_than`, `less_than`\n\nExamples\n* filter=future_symbol:\"101S6\"\n* filter=fund_code=\"0331\"\n* filter=state=FUTURES_LP_STATE_RUNNING\n* filter=fill_statistics.buy_filled_quantity \u003e 1000",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "오더링 조건 (optional, AIP-132)\n\nSupported Fields\n* \"fill_statistics.buy_filled_quantity\", \"fill_statistics.sell_filled_quantity\"\n\nExamples\n* order_by=fill_statistics.buy_filled_quantity desc",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "FuturesLpService"
        ]
      }
    },
    "/v1/futures/{futureSymbol}/lp/{fundCode}": {
      "get": {
        "summary": "선물 LP 설정 조회",
