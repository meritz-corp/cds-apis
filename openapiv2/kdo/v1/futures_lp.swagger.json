  "definitions": {
    "futures_lpFuturesLp": {
      "type": "object",
      "properties": {
        "futureSymbol": {
          "type": "string",
          "title": "선물 종목 심볼"
        },
        "fundCode": {
          "type": "string",
          "title": "펀드 코드"
        },
        "etfSymbol": {
          "type": "string",
          "title": "Reference로 사용하는 기초 ETF 심볼"
        },
        "multiplier": {
          "type": "number",
          "format": "double",
          "description": "선물 1계약 = ETF N units. 항상 양수 (Forward only)."
        },
        "askBasis": {
          "type": "number",
          "format": "double",
          "title": "LP 마진 — 이론가 위에 추가로 띄울 ask spread\n(cost of carry는 ask_basis/bid_basis에 흡수됨)"
        },
        "bidBasis": {
          "type": "number",
          "format": "double",
          "title": "LP 마진 — 이론가 아래에 추가로 띄울 bid spread"
        },
        "bidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매수 주문 수량 (계약 수)"
        },
        "askQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매도 주문 수량 (계약 수)"
        },
        "depth": {
          "type": "integer",
          "format": "int64",
          "title": "호가 깊이 (양방향 레벨 수)"
        },
        "tickSize": {
          "type": "number",
          "format": "double",
          "title": "선물 tick 크기"
        },
        "offset": {
          "$ref": "#/definitions/lpEtfLpOffset",
          "title": "자동 offset 조정 설정 (ETF LP의 EtfLpOffset 재사용)"
        },
        "enabled": {
          "type": "boolean",
          "title": "LP 활성화 여부"
        },
        "bidAdjustment": {
          "type": "number",
          "format": "double",
          "title": "매수 호가 조정값"
        },
        "askAdjustment": {
          "type": "number",
          "format": "double",
          "title": "매도 호가 조정값"
        },
        "quantityLimit": {
          "$ref": "#/definitions/futures_lpFuturesLpQuantityLimit",
          "title": "매수/매도 수량 한도"
        },
        "etfPricing": {
          "type": "string",
          "title": "EtfPricing variant 이름 (예: \"pdf_nav_hedge\", \"leverage_future\")"
        }
      },
      "title": "선물 LP 설정"
    },
    "futures_lpFuturesLpFillStatistics": {
      "type": "object",
      "properties": {
        "buyFilledQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매수 체결량 (계약 수)"
        },
        "sellFilledQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매도 체결량 (계약 수)"
        },
        "buyTotalAmount": {
          "type": "string",
          "title": "매수 총금액 (평균 단가 계산용)"
        },
        "sellTotalAmount": {
          "type": "string",
          "title": "매도 총금액 (평균 단가 계산용)"
        }
      },
      "title": "선물 LP 체결 통계 (매수/매도 체결량 및 총금액)"
    },
    "futures_lpFuturesLpOrderLimitStatus": {
      "type": "object",
      "properties": {
        "timeFrameStatus": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/futures_lpFuturesLpTimeFrameStatus"
          },
          "title": "시간 프레임별 주문 개수 현황"
        }
      },
      "title": "Order Limiter 상태"
    },
    "futures_lpFuturesLpPricing": {
      "type": "object",
      "properties": {
        "futureBidQuote": {
          "type": "number",
          "format": "double",
          "title": "산출된 선물 매수 호가"
        },
        "futureAskQuote": {
          "type": "number",
          "format": "double",
          "title": "산출된 선물 매도 호가"
        },
        "bidNav": {
          "type": "number",
          "format": "double",
          "title": "ETF reference로 계산한 선물 공정가치 NAV (bid)"
        },
        "askNav": {
          "type": "number",
          "format": "double",
          "title": "ETF reference로 계산한 선물 공정가치 NAV (ask)"
        },
        "etfBestBid": {
          "type": "number",
          "format": "double",
          "title": "현재 사용 중인 ETF best bid (입력)"
        },
        "etfBestAsk": {
          "type": "number",
          "format": "double",
          "title": "현재 사용 중인 ETF best ask (입력)"
        }
      },
      "title": "선물 LP Pricing 정보 (호가 + ETF reference)"
    },
    "futures_lpFuturesLpQuantityLimit": {
      "type": "object",
      "properties": {
        "maxBidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매수 수량 상한 (gross 누적 매수 체결 기준)"
        },
        "maxAskQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매도 수량 상한 (gross 누적 매도 체결 기준)"
        },
        "netQuantity": {
          "type": "string",
          "format": "int64",
          "title": "순포지션 (+ = 순매수, - = 순매도): gross_bid - gross_ask\n상태 조회 시 런타임 계산값으로 노출; 한도 검증에는 max_net_quantity 참조"
        },
        "maxNetQuantity": {
          "type": "string",
          "format": "int64",
          "title": "순포지션 한도 설정값 (한도 검증에 사용)\nnet_quantity \u003e 0 \u0026\u0026 net_quantity \u003e= max_net_quantity → 매수 차단\nnet_quantity \u003c 0 \u0026\u0026 |net_quantity| \u003e= max_net_quantity → 매도 차단\n미설정(None) 시 순포지션 기반 차단 비활성"
        }
      },
      "title": "매수/매도 수량 한도"
    },
    "futures_lpFuturesLpState": {
      "type": "string",
      "enum": [
        "FUTURES_LP_STATE_UNSPECIFIED",
        "FUTURES_LP_STATE_IDLE",
        "FUTURES_LP_STATE_RUNNING",
        "FUTURES_LP_STATE_STOPPING",
        "FUTURES_LP_STATE_ERROR"
      ],
      "default": "FUTURES_LP_STATE_UNSPECIFIED",
      "title": "선물 LP 상태 enum"
    },
    "futures_lpFuturesLpStatus": {
      "type": "object",
      "properties": {
        "futureSymbol": {
          "type": "string",
          "title": "선물 종목 심볼"
        },
        "fundCode": {
          "type": "string",
          "title": "펀드 코드"
