    "/v1/inventories/{fromFund}:transferLoan": {
      "post": {
        "summary": "펀드간 대차 이전 (내부대차)",
        "operationId": "InventoryService_TransferLoan",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/inventoryTransferLoanResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "fromFund",
            "description": "이전 출발 펀드 리소스명",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "funds/[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "toFund": {
                  "type": "string",
                  "title": "이전 도착 펀드 리소스명"
                },
                "symbol": {
                  "type": "string",
                  "title": "종목코드"
                },
                "quantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "이전 수량"
                },
                "borrow": {
                  "type": "boolean",
                  "title": "이전 구분 (true=차입이전, false=대여이전)"
                },
                "productPositionType": {
                  "$ref": "#/definitions/inventoryProductPositionType",
                  "title": "상품포지션구분 (PROD_PSTN_CLS_CODE)\n042c/052a InBlock2: 상품유가증권 또는 매도유가증권"
                },
                "loanTransactionType": {
                  "$ref": "#/definitions/inventoryLoanTransactionType",
                  "title": "처리구분 (PROS_CLS_CODE)\n042c InBlock1: 상환/대여/기타/펀드간상환/펀드간대여"
                }
              },
              "title": "TransferLoan 요청",
              "required": [
                "toFund",
                "symbol",
                "quantity",
                "borrow"
              ]
            }
          }
        ],
        "tags": [
          "InventoryService"
        ]
      }
    },
    "/v1/inventories/{fund}": {
      "get": {
        "summary": "펀드별 재고 현황 목록 조회",
        "operationId": "InventoryService_ListInventories",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/inventoryListInventoriesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "fund",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "funds/[^/]+"
          },
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "필터링 조건 (optional, AIP-160)\n\nAvailable Operators:\n* symbol\n  * `equal`, `contains`\n* inventory_type\n  * `equal` (INVENTORY_TYPE_STOCK, INVENTORY_TYPE_DERIV)\n* stock.sellable, stock.book_quantity\n  * `equal`, `greater_than`, `less_than`\n* deriv.quantity\n  * `equal`, `greater_than`, `less_than`\n\nExamples:\n* filter=symbol:\"005930\"\n* filter=inventory_type=INVENTORY_TYPE_STOCK\n* filter=stock.sellable \u003e 1000\n* filter=deriv.quantity \u003c 0 (Short 포지션만)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "오더링 조건 (optional, AIP-132)\n\nSupported Fields:\n* \"symbol\", \"inventory_type\"\n* \"stock.sellable\", \"stock.book_quantity\", \"stock.book_amount\"\n* \"deriv.quantity\", \"deriv.book_amount\"\n\nExamples:\n* order_by=stock.book_amount desc\n* order_by=deriv.quantity asc",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "InventoryService"
        ]
      }
    },
