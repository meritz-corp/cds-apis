              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/vi_arbitrageBasisUpdate"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of vi_arbitrageBasisUpdate"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbols",
            "description": "특정 심볼만 구독 (없으면 현재 VI 종목 전체)",
            "in": "query",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
