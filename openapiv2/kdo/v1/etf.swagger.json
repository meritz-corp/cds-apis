{
  "swagger": "2.0",
  "info": {
    "title": "kdo/v1/etf.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "EtfService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/etfs": {
      "get": {
        "operationId": "EtfService_ListEtfs",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfListEtfsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "필터링 조건 (optional, AIP-160)",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    },
    "/v1/etfs:create_redeem": {
      "post": {
        "operationId": "EtfService_CreateRedeemEtf",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfEtf"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/etfCreateRedeemEtfRequest"
            }
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    },
    "/v1/{etf}": {
      "get": {
        "operationId": "EtfService_GetEtf",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfEtf"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "etf",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "etfs/[^/]+"
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    },
    "/v1/{etf}/tick_impact": {
      "get": {
        "summary": "구성종목 1틱 변동 시 ETF NAV 영향 조회",
        "operationId": "EtfService_GetEtfTickImpact",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfEtfTickImpact"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "etf",
            "description": "ETF 리소스 이름 (예: etfs/069500)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "etfs/[^/]+"
          },
          {
            "name": "constituentSymbol",
            "description": "구성종목 심볼",
            "in": "query",
            "required": true,
            "type": "string"
          },
          {
            "name": "basePrice",
            "description": "기준가 (이 가격을 중심으로 위아래 틱 계산)",
            "in": "query",
            "required": true,
            "type": "string"
          },
          {
            "name": "tickRange",
            "description": "위아래 계산할 틱 수 (예: 3이면 base_price 기준 -3틱 ~ +3틱)",
            "in": "query",
            "required": true,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    },
    "/v1/{etf}:calc_unit_price": {
      "post": {
        "summary": "ETF-선물 헷지 포지션의 단가를 계산합니다.",
        "operationId": "EtfService_CalcEtfUnitPrice",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfCalcEtfUnitPriceResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "etf",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "etfs/[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "pricing": {
                  "$ref": "#/definitions/commonEtfPricing",
                  "title": "가격 산출 방식 (IndexTrackingHedge / LeverageFuture 만 지원)"
                },
                "etfSide": {
                  "$ref": "#/definitions/commonOrderSide",
                  "title": "ETF 체결 방향 (Bid=매수 / Ask=매도)"
                },
                "etfQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "ETF 체결 수량"
                },
                "etfPrice": {
                  "type": "string",
                  "title": "ETF 체결 가격"
                },
                "hedgeSide": {
                  "$ref": "#/definitions/commonOrderSide",
                  "title": "헷지(선물) 방향"
                },
                "hedgeQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "헷지(선물) 수량"
                },
                "hedgePrice": {
                  "type": "string",
                  "title": "헷지(선물) 가격"
                },
                "targetUnitPrice": {
                  "type": "string",
                  "title": "타겟 단가 (optional, 제공 시 PnL 계산)"
                }
              },
              "title": "CalcEtfUnitPrice",
              "required": [
                "pricing",
                "etfSide",
                "etfQuantity",
                "etfPrice",
                "hedgeSide",
                "hedgeQuantity",
                "hedgePrice"
              ]
            }
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    },
    "/v1/{etf}:get_constituents": {
      "post": {
        "summary": "pricing 종류에 따라 결정된 ETF 구성종목을 조회합니다.\nPdfDecomposeHedge pricing의 경우 sub-ETF를 leaf(Stock/Futures/Cash)로 재귀 분해한\nflattened 버전을 반환합니다.",
        "operationId": "EtfService_GetEtfConstituents",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfGetEtfConstituentsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "etf",
            "description": "ETF 리소스 이름 (예: etfs/069500)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "etfs/[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "pricing": {
                  "$ref": "#/definitions/commonEtfPricing",
                  "title": "가격 산출 방식 (pricing 종류에 따라 flattened 여부가 결정됨)"
                }
              },
              "title": "GetEtfConstituents",
              "required": [
                "pricing"
              ]
            }
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    },
    "/v1/{etf}:update_unit_delta": {
      "post": {
        "operationId": "EtfService_UpdateEtfUnitDelta",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/etfEtf"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "etf",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "etfs/[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "unitDelta": {
                  "type": "string"
                }
              },
              "required": [
                "unitDelta"
              ]
            }
          }
        ],
        "tags": [
          "EtfService"
        ]
      }
    }
  },
  "definitions": {
    "commonEtfPricing": {
      "type": "object",
      "properties": {
        "pdfNavHedge": {
          "$ref": "#/definitions/commonPdfNavHedgePricing",
          "title": "분해 헷지 방식"
        },
        "indexTrackingHedge": {
          "$ref": "#/definitions/commonIndexTrackingHedgePricing",
          "title": "선물 헷지 방식"
        },
        "futureBasis": {
          "$ref": "#/definitions/commonFutureBasis"
        },
        "leverageFuture": {
          "$ref": "#/definitions/commonLeverageFuturePricing",
          "title": "레버리지 선물 방식"
        },
        "pdfDecomposeHedge": {
          "$ref": "#/definitions/commonPdfDecomposeHedgePricing",
          "title": "PDF 재귀 분해 헷지 방식: leaf가 단일 종목으로 귀결되는 ETF에 대한 프라이싱"
        }
      },
      "title": "ETF 가격 산출 방식"
    },
    "commonFutureBasis": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "string"
        }
      }
    },
    "commonIndexTrackingHedgePricing": {
      "type": "object",
      "title": "선물 헷지 가격 산출"
    },
    "commonLeverageFuturePricing": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "number",
          "format": "double",
          "title": "기초지수 전일종가"
        },
        "prevFuture": {
          "type": "number",
          "format": "double",
          "title": "선물 전일종가"
        }
      },
      "title": "레버리지 선물 가격 산출"
    },
    "commonOrderSide": {
      "type": "string",
      "enum": [
        "ORDER_SIDE_UNSPECIFIED",
        "ORDER_SIDE_BID",
        "ORDER_SIDE_ASK"
      ],
      "default": "ORDER_SIDE_UNSPECIFIED",
      "description": "- ORDER_SIDE_BID: 매수\n - ORDER_SIDE_ASK: 매도",
      "title": "주문 방향"
    },
    "commonPdfDecomposeHedgePricing": {
      "type": "object",
      "description": "PDF 재귀 분해 헷지 가격 산출 (파라미터 없음)\nNAV 계산은 Etf.decomposed_constituents를 PdfNavHedge와 동일 공식으로 적용."
    },
    "commonPdfNavHedgePricing": {
      "type": "object",
      "title": "분해 헷지 가격 산출 (추가 파라미터 없음)"
    },
    "commonProductType": {
      "type": "string",
      "enum": [
        "PRODUCT_TYPE_UNSPECIFIED",
        "PRODUCT_TYPE_STOCK",
        "PRODUCT_TYPE_FUTURES",
        "PRODUCT_TYPE_ETF",
        "PRODUCT_TYPE_CASH"
      ],
      "default": "PRODUCT_TYPE_UNSPECIFIED",
      "title": "상품 타입"
    },
    "etfCalcEtfUnitPriceResponse": {
      "type": "object",
      "properties": {
        "unitPrice": {
          "type": "string",
          "title": "계산된 단가"
        },
        "pnl": {
          "type": "string",
          "title": "(unit_price - target_unit_price) × etf_quantity, target 제공 시에만"
        }
      }
    },
    "etfConversion": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "변환 대상 심볼"
        },
        "productType": {
          "$ref": "#/definitions/commonProductType",
          "title": "변환 대상 상품 타입"
        },
        "ratioPerCu": {
          "type": "number",
          "format": "double",
          "title": "1 CU당 변환 비율\n예: KODEX 2X Inverse → 코스피200 선물 = -0.37"
        }
      },
      "title": "ETF가 다른 상품으로 변환될 수 있는 정보\n예: KODEX 2X Inverse는 1cu당 -0.37개의 코스피200 선물로 변환 가능"
    },
    "etfCreateRedeemEtfRequest": {
      "type": "object",
      "properties": {
        "etf": {
          "type": "string"
        },
        "fund": {
          "type": "string"
        },
        "quantity": {
          "type": "string",
          "format": "int64"
        },
        "isCreation": {
          "type": "boolean"
        }
      },
      "required": [
        "etf",
        "fund",
        "quantity",
        "isCreation"
      ]
    },
    "etfEtf": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uint64",
          "title": "ETF ID"
        },
        "symbol": {
          "type": "string",
          "title": "ETF 심볼 (ISIN 코드)"
        },
        "code": {
          "type": "string",
          "title": "ETF 코드"
        },
        "name": {
          "type": "string",
          "title": "ETF 이름"
        },
        "prevClose": {
          "type": "string",
          "title": "마지막 가격"
        },
        "prevCloseNav": {
          "type": "string"
        },
        "lastPrice": {
          "type": "string"
        },
        "lastAskInav": {
          "type": "string"
        },
        "lastBidInav": {
          "type": "string"
        },
        "constituents": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/etfEtfPdfConstituent"
          },
          "title": "PDF 구성 종목 목록"
        },
        "creationUnit": {
          "type": "string",
          "format": "int64",
          "title": "설정 단위"
        },
        "replicationMethod": {
          "$ref": "#/definitions/etfReplicationMethod",
          "title": "복제 방법"
        },
        "tickSize": {
          "type": "string",
          "format": "int64",
          "title": "Tick 크기 (원 단위, i64)"
        },
        "listedQuantity": {
          "type": "string",
          "format": "int64",
          "title": "Tick 크기 (원 단위, i64)"
        },
        "leverage": {
          "type": "number",
          "format": "float"
        },
        "tradable": {
          "type": "boolean"
        },
        "shortSellable": {
          "type": "boolean"
        },
        "trackingAsset": {
          "$ref": "#/definitions/etfUnderlyingAsset",
          "title": "기초자산 정보"
        },
        "cashCreditable": {
          "type": "boolean"
        },
        "cashCreationAmount": {
          "type": "string",
          "format": "int64"
        },
        "conversions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/etfConversion"
          },
          "title": "ETF 변환 정보 (예: 레버리지/인버스 ETF의 선물 변환)"
        },
        "unitDelta": {
          "type": "string",
          "title": "unit_delta (구성종목 기반 NAV 계산용)"
        }
      }
    },
    "etfEtfPdfConstituent": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "symbol",
          "title": "종목 코드"
        },
        "name": {
          "type": "string",
          "title": "종목명"
        },
        "productType": {
          "$ref": "#/definitions/commonProductType",
          "title": "상품 타입"
        },
        "quantity": {
          "type": "string",
          "format": "int64",
          "title": "구성 수량 (선물 숏의 경우 음수)"
        }
      },
      "title": "PDF 구성 종목"
    },
    "etfEtfTickImpact": {
      "type": "object",
      "properties": {
        "etfSymbol": {
          "type": "string",
          "title": "ETF 심볼"
        },
        "constituentSymbol": {
          "type": "string",
          "title": "구성종목 심볼"
        },
        "currentNav": {
          "type": "string",
          "title": "현재 ETF NAV"
        },
        "currentPrice": {
          "type": "string",
          "title": "구성종목 현재가"
        },
        "points": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/etfTickNavPoint"
          },
          "title": "틱 변동별 NAV 시뮬레이션 결과 (-tick_range ~ +tick_range 순서)"
        }
      },
      "title": "ETF 틱 임팩트 응답"
    },
    "etfGetEtfConstituentsResponse": {
      "type": "object",
      "properties": {
        "constituents": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/etfEtfPdfConstituent"
          },
          "title": "pricing에 따라 flattened 여부가 결정된 구성종목 맵\nPdfDecomposeHedge: leaf(Stock/Futures/Cash)로 재귀 분해된 flattened 버전\n그 외: 원본 PDF 구성종목"
        }
      }
    },
    "etfListEtfsResponse": {
      "type": "object",
      "properties": {
        "etfs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/etfEtf"
          },
          "title": "ETF 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "etfReplicationMethod": {
      "type": "string",
      "enum": [
        "REPLICATION_METHOD_UNSPECIFIED",
        "REPLICATION_METHOD_ACTIVE",
        "REPLICATION_METHOD_PHYSICAL",
        "REPLICATION_METHOD_SYNTHETIC"
      ],
      "default": "REPLICATION_METHOD_UNSPECIFIED",
      "title": "복제 방법"
    },
    "etfTickNavPoint": {
      "type": "object",
      "properties": {
        "tickOffset": {
          "type": "integer",
          "format": "int32",
          "title": "틱 오프셋 (예: -3, -2, -1, 0, +1, +2, +3)"
        },
        "price": {
          "type": "string",
          "title": "해당 틱에서의 구성종목 가격"
        },
        "nav": {
          "type": "string",
          "title": "해당 틱에서의 ETF NAV"
        }
      },
      "title": "틱 변동에 따른 NAV 포인트"
    },
    "etfUnderlyingAsset": {
      "type": "object",
      "properties": {
        "future": {
          "$ref": "#/definitions/etfUnderlyingFuture",
          "title": "선물형"
        },
        "fixedIncome": {
          "$ref": "#/definitions/etfUnderlyingFixedIncome",
          "title": "채권형"
        },
        "commodity": {
          "$ref": "#/definitions/etfUnderlyingCommodity",
          "title": "원자재형"
        },
        "currency": {
          "$ref": "#/definitions/etfUnderlyingCurrency",
          "title": "통화형"
        }
      },
      "title": "기초자산"
    },
    "etfUnderlyingCommodity": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "종목 심볼"
        }
      },
      "title": "원자재형 기초자산"
    },
    "etfUnderlyingCurrency": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "종목 심볼"
        }
      },
      "title": "통화형 기초자산"
    },
    "etfUnderlyingFixedIncome": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "종목 심볼"
        }
      },
      "title": "채권형 기초자산"
    },
    "etfUnderlyingFuture": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "선물 종목 심볼"
        },
        "multiple": {
          "type": "string",
          "title": "승수"
        },
        "lastAskPrice": {
          "type": "string",
          "title": "최근 매도호가"
        },
