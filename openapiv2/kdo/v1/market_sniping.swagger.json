          "title": "ask 가격 조정값 (Price internal representation)"
        },
        "baseQuantity": {
          "type": "string",
          "format": "int64",
          "title": "기본 주문 수량"
        },
        "momentum": {
          "$ref": "#/definitions/market_snipingMarketSnipingMomentumSignal",
          "title": "Momentum Signal 설정"
        },
        "entryPolicy": {
          "$ref": "#/definitions/market_snipingMarketSnipingEntryPolicy",
          "title": "진입 정책"
        },
        "exitPolicy": {
          "$ref": "#/definitions/market_snipingMarketSnipingExitPolicy",
          "title": "청산 정책"
        },
        "exposureBalancer": {
          "$ref": "#/definitions/market_snipingMarketSnipingExposureBalancer",
          "title": "노출 균형 관리 설정"
        },
        "screening": {
          "$ref": "#/definitions/market_snipingMarketSnipingScreening",
          "title": "스크리닝 설정"
        },
        "executionPolicy": {
          "$ref": "#/definitions/market_snipingExecutionPolicy",
          "title": "주문 실행 방식"
        },
        "strategy": {
          "$ref": "#/definitions/market_snipingStrategyKind",
          "title": "전략 종류"
        },
        "exitAmendMethod": {
          "$ref": "#/definitions/commonAmendMethodType",
          "title": "청산 주문 자동정정 방식"
        }
      },
      "title": "Market Sniping 메인 설정"
    },
    "market_snipingMarketSnipingEntry": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
