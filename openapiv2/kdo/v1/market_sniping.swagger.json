  "definitions": {
    "commonAmendMethodType": {
      "type": "string",
      "enum": [
        "AMEND_METHOD_TYPE_UNSPECIFIED",
        "AMEND_METHOD_TYPE_AGGRESSIVE",
        "AMEND_METHOD_TYPE_EVASIVE",
        "AMEND_METHOD_TYPE_BEST_PRICE",
        "AMEND_METHOD_TYPE_STOP_LOSS",
        "AMEND_METHOD_TYPE_TIMED_MARKET"
      ],
      "default": "AMEND_METHOD_TYPE_UNSPECIFIED",
      "description": "- AMEND_METHOD_TYPE_UNSPECIFIED: 미지정 (기본값: TIMED_MARKET으로 처리)\n - AMEND_METHOD_TYPE_AGGRESSIVE: 적극적 정정: 반대편 잔량 비율이 임계값 이상이면 즉시 체결 시도\n - AMEND_METHOD_TYPE_EVASIVE: 회피적 정정: tick_offset 만큼 가격을 조정하여 미체결 유지\n - AMEND_METHOD_TYPE_BEST_PRICE: 최우선 호가: 상대방 최우선 호가로 정정\n - AMEND_METHOD_TYPE_STOP_LOSS: 손절 정정: tick_threshold 이상 불리해지면 시장가로 전환\n - AMEND_METHOD_TYPE_TIMED_MARKET: 시간 제한 시장가: timeout 후 시장가로 전환",
      "title": "자동정정 전략 유형"
    },
    "market_snipingCreateMarketSnipingRequest": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ISIN 심볼"
        },
        "config": {
          "$ref": "#/definitions/market_snipingMarketSnipingConfig",
          "title": "Market Sniping 설정"
        },
        "navConfig": {
          "$ref": "#/definitions/market_snipingMarketSnipingNavConfig",
          "title": "NAV 설정"
        }
      },
      "title": "CreateMarketSniping",
      "required": [
        "symbol",
        "config",
        "navConfig"
      ]
    },
    "market_snipingExecutionPolicy": {
      "type": "string",
      "enum": [
        "EXECUTION_POLICY_UNSPECIFIED",
        "EXECUTION_POLICY_PASSIVE_LIMIT",
        "EXECUTION_POLICY_IMMEDIATE_OR_CANCEL"
      ],
      "default": "EXECUTION_POLICY_UNSPECIFIED",
      "description": "- EXECUTION_POLICY_PASSIVE_LIMIT: 수동 지정가\n - EXECUTION_POLICY_IMMEDIATE_OR_CANCEL: IOC",
      "title": "진입/청산 주문 방식"
    },
    "market_snipingListMarketSnipingResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/market_snipingMarketSnipingEntry"
          },
          "title": "등록된 Market Sniping 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "market_snipingMarketSnipingConditionalExitPolicy": {
      "type": "object",
      "properties": {
        "exitOnSignalEnd": {
          "type": "boolean",
          "title": "신호 종료 시 청산"
        },
        "exitOnReverseSignal": {
          "type": "boolean",
          "title": "역방향 신호 시 청산"
        },
        "maxHoldingMs": {
          "type": "string",
          "format": "uint64",
          "title": "최대 보유 시간 (ms, 0 = 제한 없음)"
        },
        "minProfitTicks": {
          "type": "integer",
          "format": "int32",
          "title": "최소 수익 틱 (0 = 제한 없음)"
        },
        "maxLossTicks": {
          "type": "integer",
          "format": "int32",
          "title": "최대 손실 틱 (0 = 제한 없음)"
        }
      },
      "title": "조건부 청산 정책 (ConditionalExitPolicy)"
    },
    "market_snipingMarketSnipingConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
