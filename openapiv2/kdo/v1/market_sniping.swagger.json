      "properties": {
        "minSignalStrength": {
          "type": "number",
          "format": "double",
          "title": "최소 신호 강도"
        },
        "cooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "재진입 쿨다운 (ms)"
        },
        "maxEntryQuantity": {
          "type": "string",
          "format": "int64",
          "title": "최대 진입 수량 (0 = 제한 없음)"
        }
      },
      "title": "진입 정책"
    },
    "market_snipingMarketSnipingExitPolicy": {
      "type": "object",
      "properties": {
        "alwaysExit": {
          "type": "boolean",
          "title": "항상 전량 청산"
        },
        "conditional": {
          "$ref": "#/definitions/market_snipingMarketSnipingConditionalExitPolicy",
          "title": "조건부 청산 정책"
        }
      },
      "title": "청산 정책 (oneof: 항상 청산 | 조건부 청산)"
    },
    "market_snipingMarketSnipingExposureBalancer": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "minExitQuantity": {
          "type": "string",
          "format": "int64",
          "title": "부분 청산 최소 수량"
        },
        "partialExitRatio": {
          "type": "number",
          "format": "double",
