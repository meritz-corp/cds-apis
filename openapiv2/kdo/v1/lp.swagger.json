            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "오더링 조건. (optional, AIP-132)\n\nSupported Fields\n* \"fill_statistics.buy_filled_quantity\", \"fill_statistics.sell_filled_quantity\"\n\nExamples\n* order_by=fill_statistics.buy_filled_quantity desc",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "LpService"
        ]
      }
    },
    "/v1/lps/etfs/{symbol}/funds/{fundCode}": {
      "patch": {
        "summary": "ETF LP 업데이트",
        "operationId": "LpService_UpdateEtfLp",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/lpEtfLp"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ETF 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "fundCode",
            "description": "펀드 코드",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "depth": {
                  "type": "integer",
                  "format": "int64",
                  "title": "호가 깊이"
                },
                "offset": {
                  "$ref": "#/definitions/lpEtfLpOffset",
                  "title": "동적 offset 조정 설정"
                },
                "askBasis": {
                  "type": "number",
                  "format": "double"
                },
                "bidBasis": {
                  "type": "number",
                  "format": "double"
                },
                "bidQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "매수 주문 수량"
                },
                "askQuantity": {
                  "type": "string",
                  "format": "int64",
                  "title": "매도 주문 수량"
                },
                "bidAdjustment": {
                  "type": "number",
                  "format": "double",
                  "title": "매수 호가 조정값"
                },
                "askAdjustment": {
                  "type": "number",
                  "format": "double",
                  "title": "매도 호가 조정값"
                },
                "momentumEnabled": {
                  "type": "boolean",
                  "title": "모멘텀 활성화 여부"
                },
                "momentumWindow": {
                  "type": "integer",
                  "format": "int64",
                  "title": "모멘텀 윈도우 크기"
                },
                "momentumSensitivity": {
                  "type": "number",
                  "format": "double",
                  "title": "모멘텀 민감도"
                },
                "quantityLimit": {
                  "$ref": "#/definitions/lpEtfLpQuantityLimit",
                  "title": "매수/매도 수량 한도"
                },
                "precomputePolicy": {
                  "$ref": "#/definitions/lpPrecomputePolicy",
                  "title": "precomputed quote retreat 처리 정책"
                }
              },
              "title": "UpdateEtfLp"
            }
          }
        ],
        "tags": [
          "LpService"
        ]
      }
    },
