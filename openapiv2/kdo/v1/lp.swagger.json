  "definitions": {
    "commonEtfPricing": {
      "type": "object",
      "properties": {
        "pdfNavHedge": {
          "$ref": "#/definitions/commonPdfNavHedgePricing",
          "title": "분해 헷지 방식"
        },
        "indexTrackingHedge": {
          "$ref": "#/definitions/commonIndexTrackingHedgePricing",
          "title": "선물 헷지 방식"
        },
        "futureBasis": {
          "$ref": "#/definitions/commonFutureBasis"
        },
        "leverageFuture": {
          "$ref": "#/definitions/commonLeverageFuturePricing",
          "title": "레버리지 선물 방식"
        },
        "pdfDecomposeHedge": {
          "$ref": "#/definitions/commonPdfDecomposeHedgePricing",
          "title": "PDF 재귀 분해 헷지 방식: leaf가 단일 종목으로 귀결되는 ETF에 대한 프라이싱"
        }
      },
      "title": "ETF 가격 산출 방식"
    },
    "commonFutureBasis": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "string"
        }
      }
    },
    "commonIndexTrackingHedgePricing": {
      "type": "object",
      "title": "선물 헷지 가격 산출"
    },
    "commonLeverageFuturePricing": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "number",
          "format": "double",
          "title": "기초지수 전일종가"
        },
        "prevFuture": {
          "type": "number",
          "format": "double",
          "title": "선물 전일종가"
        }
      },
      "title": "레버리지 선물 가격 산출"
    },
    "commonPdfDecomposeHedgePricing": {
      "type": "object",
      "description": "PDF 재귀 분해 헷지 가격 산출 (파라미터 없음)\nNAV 계산은 Etf.decomposed_constituents를 PdfNavHedge와 동일 공식으로 적용."
    },
    "commonPdfNavHedgePricing": {
      "type": "object",
      "title": "분해 헷지 가격 산출 (추가 파라미터 없음)"
    },
    "lpEtfLp": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ETF 심볼"
        },
        "fundCode": {
          "type": "string",
          "title": "Fund"
        },
        "askBasis": {
          "type": "number",
          "format": "double"
        },
        "bidBasis": {
          "type": "number",
          "format": "double"
        },
        "depth": {
          "type": "integer",
          "format": "int64",
          "title": "호가 깊이 (양방향 레벨 수)"
        },
        "tickSize": {
          "type": "string",
          "format": "int64",
          "title": "ETF tick 크기 (원 단위, i64)"
        },
        "offset": {
          "$ref": "#/definitions/lpEtfLpOffset",
          "title": "동적 offset 조정 설정"
        },
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "pricingMethod": {
          "$ref": "#/definitions/commonEtfPricing",
          "title": "ETF 가격 산출 방식"
        },
        "bidAdjustment": {
          "type": "number",
          "format": "double",
          "title": "매수 호가 조정값"
        },
        "askAdjustment": {
          "type": "number",
          "format": "double",
          "title": "매도 호가 조정값"
        },
        "bidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매수 주문 수량 (i64)"
        },
        "askQuantity": {
          "type": "string",
          "format": "int64",
          "title": "매도 주문 수량 (i64)"
        },
        "momentumEnabled": {
          "type": "boolean",
          "title": "모멘텀 활성화 여부"
        },
        "momentumWindow": {
          "type": "integer",
          "format": "int64",
          "title": "모멘텀 윈도우 크기"
        },
        "momentumSensitivity": {
          "type": "number",
          "format": "double",
          "title": "모멘텀 민감도"
        },
        "quantityLimit": {
          "$ref": "#/definitions/lpEtfLpQuantityLimit",
          "title": "매수/매도 수량 한도"
        },
        "precomputePolicy": {
          "$ref": "#/definitions/v1lpPrecomputePolicy",
          "title": "precomputed quote retreat 처리 정책"
        },
        "pricingSourceLiquidityImbalanceGuardEnabled": {
          "type": "boolean",
          "title": "pricing source 선물 1호가 잔량 imbalance guard 활성화 여부\n선물 1호가 잔량이 반대편의 30% 이하로 imbalance 발생 시 영향받는 ETF side 주문 자동 cancel"
        },
        "portfolioId": {
          "type": "integer",
          "format": "int32",
          "title": "포트폴리오 ID (응답용 - portfolio_fund 에서 derive)"
        },
        "bidEnabled": {
          "type": "boolean",
          "title": "매수 호가 활성화 여부 (enabled=true 일 때만 적용. false=매수 호가 중단)"
        },
        "askEnabled": {
          "type": "boolean",
          "title": "매도 호가 활성화 여부 (enabled=true 일 때만 적용. false=매도 호가 중단)"
        }
      },
      "title": "ETF LP 설정"
    },
    "lpEtfLpOffset": {
      "type": "object",
      "properties": {
        "bidOffset": {
          "type": "number",
          "format": "double",
          "description": "optional: 미설정(None) 시 해당 필드를 덮어쓰지 않음.\nproto3 optional scalar → prost::Message 에서 Option\u003cT\u003e로 생성됨."
        },
        "askOffset": {
          "type": "number",
