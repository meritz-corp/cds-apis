    "/v1/lps/{etf}/{fund}:clearOrderBook": {
      "post": {
        "summary": "사용자 주문 오더북을 강제로 비웁니다.\nLP 가 Running 상태일 때는 호출 불가 (FailedPrecondition 반환).\nLP 가 Idle / Stopping / Error 상태일 때만 사용 가능.\n운영 중 좀비 주문이 누적된 경우 수동 복구용.",
        "operationId": "LpService_ClearUserOrderBook",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/lpClearUserOrderBookResponse"
            }
          },
          "default": {
