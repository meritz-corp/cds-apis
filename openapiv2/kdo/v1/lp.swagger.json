            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "etf",
            "description": "ETF resource: \"etfs/{symbol}\"",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "etfs/[^/]+"
          },
          {
            "name": "fund",
            "description": "Fund resource: \"funds/{fund_code}\"",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "funds/[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
