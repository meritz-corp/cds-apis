            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "fund",
            "description": "펀드 리소스 이름 (예: funds/KR1234567890)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "funds/[^/]+"
          }
        ],
        "tags": [
          "FundService"
        ]
      }
    },
    "/v1/{fund}/limits": {
