                  "title": "Pair ID",
                  "readOnly": true
                },
                "displayName": {
                  "type": "string",
                  "title": "전략 이름 (고유)"
                },
                "portfolioId": {
                  "type": "integer",
                  "format": "int32",
                  "title": "Portfolio ID"
                },
                "base": {
                  "$ref": "#/definitions/pairPairEntry",
                  "title": "Base 엔트리"
                },
                "counter": {
                  "$ref": "#/definitions/pairPairEntry",
                  "title": "Counter 엔트리"
                },
                "status": {
                  "$ref": "#/definitions/pairPairStatus",
                  "title": "상태",
                  "readOnly": true
                },
                "createTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "생성 시간",
                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "수정 시간",
                  "readOnly": true
                },
                "trigger": {
                  "$ref": "#/definitions/v1pairTriggerCondition",
                  "description": "트리거 — 언제 발사할지. 실행(execution)과 독립적으로 조합한다."
                },
                "execution": {
                  "$ref": "#/definitions/pairOrderExecution",
                  "description": "실행 — 발사 시 무엇을 할지. 트리거(trigger)와 독립적으로 조합한다."
                },
                "nav": {
                  "$ref": "#/definitions/v1pairNav",
                  "description": "ETF↔Future NAV 환산 설정 — TargetNavQuantityImbalance 트리거·BaseMakeCounterIocAndBalance/CounterIocTpSlExecution\nexecution 이 공유. NAV 미사용 페어는 미설정."
                },
                "baseQuantityLimit": {
                  "$ref": "#/definitions/pairPairQuantityLimit",
                  "title": "base leg 누적 체결 수량 한도"
                }
              },
              "title": "수정할 Pair",
              "required": [
                "displayName",
                "portfolioId",
                "base",
                "counter"
              ]
            }
          },
          {
            "name": "baseQuantityLimit.maxBidQuantity",
            "description": "매수 수량 상한 (gross 누적 매수 체결 기준)",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "baseQuantityLimit.maxAskQuantity",
            "description": "매도 수량 상한 (gross 누적 매도 체결 기준)",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "baseQuantityLimit.netQuantity",
            "description": "순포지션 (+ = 순매수, - = 순매도): gross_bid - gross_ask\n상태 조회 시 런타임 계산값으로 노출; 한도 검증에는 max_net_quantity 참조",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "baseQuantityLimit.maxNetQuantity",
            "description": "순포지션 한도 설정값 (한도 검증에 사용)\nnet_quantity \u003e 0 \u0026\u0026 net_quantity \u003e= max_net_quantity → 매수 차단\nnet_quantity \u003c 0 \u0026\u0026 |net_quantity| \u003e= max_net_quantity → 매도 차단\n미설정(None) 시 순포지션 기반 차단 비활성",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          }
        ],
        "tags": [
          "PairService"
        ]
      }
    },
