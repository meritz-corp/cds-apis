            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "필터링 조건 (optional, AIP-160)\n\nAvailable Fields:\n* status - 상태 (ACTIVE / PAUSED / ARCHIVED)\n* portfolio_id - Portfolio ID\n\nExamples:\n* status=ACTIVE\n* portfolio_id=1",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "PairService"
        ]
      },
      "post": {
