  "definitions": {
    "pairBestMakeQuantityImbalanceTrigger": {
      "type": "object",
      "properties": {
        "thresholdRatio": {
          "type": "number",
          "format": "double",
          "title": "base 1호가 imbalance 가 이 비율 미만이면 트리거"
        },
        "cooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "트리거 후 재트리거까지 대기시간 (ms)"
        }
      },
      "description": "base 자기측(BestMake) 1호가 수량 불균형 트리거. base.side 가 담당 deficit 방향."
    },
    "pairCounterBepScalpExecution": {
      "type": "object",
      "properties": {
        "takeProfitTicks": {
          "type": "integer",
          "format": "int64",
          "title": "익절 임계 (틱)"
        },
        "stopLossTicks": {
          "type": "integer",
          "format": "int64",
          "title": "손절 임계 (틱)"
        },
        "exitAggressiveTicks": {
          "type": "integer",
          "format": "int64",
          "title": "청산 발주 시 상대 1호가 대비 추가 공격 틱 (0 = 상대호가 그대로)"
        },
        "entryAggressiveTicks": {
          "type": "integer",
          "format": "int64",
          "description": "진입 발주 시 상대 1호가에서 추가로 공격적으로 낼 틱 수 (0 = 상대호가 그대로).\n진입은 BEP 가 아니라 상대호가 ± n틱의 pseudo-IOC (접수 후 잔량 즉시 취소)."
        },
        "exitDelayMs": {
          "type": "string",
          "format": "uint64",
          "description": "익절/손절 판정 대기 시간 (ms). 마지막 진입 체결 시각부터 이 시간 경과 후 판정 시작."
        }
      },
      "description": "base 무발주 — counter(ETF) 상대호가±N틱 pseudo-IOC 진입 + 마지막 진입 체결가 대비 틱 기준 익절/손절.\n진입 주문은 상대 1호가에서 entry_aggressive_ticks 만큼 공격적으로 제출 후 잔량 즉시 취소(pseudo-IOC).\n익절/손절 판정은 exit_delay_ms 경과 후 시작하며, 청산 주문은 체결될 때까지 호가 추적(amend)으로 체결 보장."
    },
    "pairDualSubmitExecution": {
      "type": "object",
      "properties": {
        "orderType": {
          "$ref": "#/definitions/pairPairOrderType",
          "title": "주문 유형"
        }
      },
      "title": "양측 동시 발주 (구 SimultaneousCompare 의 실행부)"
    },
    "pairEtfNavKind": {
      "type": "string",
      "enum": [
        "ETF_NAV_KIND_UNSPECIFIED",
        "ETF_NAV_KIND_INDEX_TRACKING_HEDGE",
        "ETF_NAV_KIND_FUTURE_BASIS",
        "ETF_NAV_KIND_LEVERAGE_FUTURE",
        "ETF_NAV_KIND_PDF_DECOMPOSE_HEDGE"
      ],
      "default": "ETF_NAV_KIND_UNSPECIFIED",
      "description": "- ETF_NAV_KIND_INDEX_TRACKING_HEDGE: 지수 추종 헷지 프라이싱: (future + basis) * multiple + cash\n - ETF_NAV_KIND_FUTURE_BASIS: 선물 베이시스 기반: unit_delta * future / (prev_index + basis) + cash\n - ETF_NAV_KIND_LEVERAGE_FUTURE: 레버리지/인버스 ETF용 선물 기반\n - ETF_NAV_KIND_PDF_DECOMPOSE_HEDGE: PDF 구성종목 기반 헷지 프라이싱 (단일 선물 구성종목 전제, flatten 필수)",
      "title": "ETF NAV 계산 공식 종류"
    },
    "pairLegStatus": {
      "type": "object",
      "properties": {
        "unfilledQuantity": {
          "type": "string",
          "format": "int64",
          "title": "미체결 수량 (submitted - filled)"
        },
        "filledQuantity": {
          "type": "string",
          "format": "int64",
          "title": "누적 체결 수량 (현재 세션 메모리 카운터, 재시작 시 0)"
        },
        "avgFillPrice": {
          "type": "string",
          "format": "int64",
          "title": "체결 VWAP (milli-won 단위)"
        },
        "submittedQuantity": {
          "type": "string",
          "format": "int64",
          "title": "누적 발주 수량 (현재 세션 메모리 카운터)"
        }
      },
      "title": "페어 단일 leg 실시간 상태 스냅샷\n(태그 번호는 클라이언트 UI 계약으로 보존됨)"
    },
    "pairListPairExecutionLogsResponse": {
      "type": "object",
      "properties": {
        "executionLogs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/pairPairExecutionLog"
          },
          "title": "실행 로그 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        },
        "totalCount": {
          "type": "integer",
          "format": "int32",
          "title": "전체 건수"
        }
      }
    },
    "pairListPairsResponse": {
      "type": "object",
      "properties": {
        "pairs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/pairPair"
          },
          "title": "Pair 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "pairMakeCounterIocBalanceExecution": {
      "type": "object",
      "properties": {
        "recoveryRatio": {
          "type": "number",
          "format": "double",
          "title": "base 측 잔량 비율이 이 값을 초과하면 base 공격적 정정→강제 체결"
        },
        "settleTimeoutMs": {
          "type": "string",
          "format": "uint64",
          "title": "결제(settle) 타임아웃 (ms, 이 시간 내 미결제 시 경보)"
        },
        "reconcileAlertAmount": {
          "type": "string",
          "format": "int64",
          "title": "잔량 조정 경보 임계값 (원, 이 금액 초과 시 경보 로그)"
        },
        "baseRecoveryAggressiveTicks": {
          "type": "integer",
          "format": "int64",
          "description": "base leg 공격적 정정 시 상대호가(cross price) 보다 얼마나 더 공격적으로 낼지 (tick 단위).\n0 이면 상대호가/ref 그대로. Bid 면 +N*tick, Ask 면 -N*tick."
        },
        "counterRecoveryAggressiveTicks": {
          "type": "integer",
          "format": "int64",
          "description": "counter leg 공격적 정정 시 상대호가에서 얼마나 더 공격적으로 낼지 (tick 단위).\n0 이면 BEP 그대로. counter.side 가 Bid 면 +N*tick, Ask 면 -N*tick."
        }
      },
