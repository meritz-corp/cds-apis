  "definitions": {
    "pairBaseMakeCounterIocAndBalance": {
      "type": "object",
      "properties": {
        "counterInverse": {
          "type": "boolean",
          "title": "counter leg 역방향 여부 (true: counter 측 방향을 base와 반대로 설정)\ncounter.side = counter_inverse ? base.side : base.side.opposite()"
        },
        "imbalanceThresholdRatio": {
          "type": "number",
          "format": "double",
          "title": "IOC 발주 시 불균형 감지 임계 비율 (잔량 / 목표수량, 이 값 초과 시 재발주)"
        },
        "imbalanceRecoveryRatio": {
          "type": "number",
          "format": "double",
          "title": "불균형 회복 목표 비율 (재발주 시 목표 충족 비율)"
        },
        "settleTimeoutMs": {
          "type": "string",
          "format": "uint64",
          "title": "결제(settle) 타임아웃 (ms, 이 시간 내 미결제 시 경보)"
        },
        "reconcileAlertAmount": {
          "type": "string",
          "format": "int64",
          "title": "잔량 조정 경보 임계값 (원, 이 금액 초과 시 경보 로그)"
        },
        "cooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "트리거 후 재트리거까지 대기시간 (ms)"
        },
        "navKind": {
          "$ref": "#/definitions/pairEtfNavKind",
          "title": "NAV 계산 공식 종류 (서버 런타임에 PricingContext 엔티티 조회, proto엔 종류만 지정)"
        },
        "bidBasis": {
          "type": "string",
          "format": "int64",
          "title": "Bid quote 산출용 basis 오프셋 (원, raw int64)"
        },
        "askBasis": {
          "type": "string",
          "format": "int64",
          "title": "Ask quote 산출용 basis 오프셋 (원, raw int64)"
        }
      },
      "description": "PairEntry 필드 매핑:\n  - base.symbol / base.fund_code / base.side / base.quantity: 사용 (필수).\n  - counter.symbol / counter.fund_code: 사용 (필수).\n  - counter.side / counter.quantity: 자동 파생 (counter.side = base.side ± counter_inverse,\n    counter.quantity = base.quantity × hedge_ratio). 입력값은 무시 — UNSPECIFIED / 0 으로 비워도 된다.\n  - PairEntry.price_source / price_offset_ticks (양 leg): 무시. base 가격은 base.side 의 1호가,\n    counter 가격은 NAV 기반 BEP. 서버에서 UNSPECIFIED / 0 으로 정규화한다.",
      "title": "BaseMakeCounterIocAndBalance 모드 설정 (IOC imbalance hotpath)"
    },
    "pairEtfNavKind": {
      "type": "string",
      "enum": [
        "ETF_NAV_KIND_UNSPECIFIED",
        "ETF_NAV_KIND_INDEX_TRACKING_HEDGE",
        "ETF_NAV_KIND_FUTURE_BASIS",
        "ETF_NAV_KIND_LEVERAGE_FUTURE"
      ],
      "default": "ETF_NAV_KIND_UNSPECIFIED",
      "description": "- ETF_NAV_KIND_INDEX_TRACKING_HEDGE: 지수 추종 헷지 프라이싱: (future + basis) * multiple + cash\n - ETF_NAV_KIND_FUTURE_BASIS: 선물 베이시스 기반: unit_delta * future / (prev_index + basis) + cash\n - ETF_NAV_KIND_LEVERAGE_FUTURE: 레버리지/인버스 ETF용 선물 기반",
      "title": "ETF NAV 계산 공식 종류\n(PdfNavHedge/PdfDecomposeHedge는 Pair 미지원 — 서버에서 거부됨)"
    },
    "pairLegStatus": {
      "type": "object",
      "properties": {
        "unfilledQuantity": {
          "type": "string",
          "format": "int64",
          "title": "미체결 수량 (submitted - filled)"
        },
        "filledQuantity": {
          "type": "string",
          "format": "int64",
          "title": "누적 체결 수량 (현재 세션 메모리 카운터, 재시작 시 0)"
        },
        "avgFillPrice": {
          "type": "string",
          "format": "int64",
          "title": "체결 VWAP (milli-won 단위)"
        },
        "submittedQuantity": {
          "type": "string",
          "format": "int64",
          "title": "누적 발주 수량 (현재 세션 메모리 카운터)"
        }
      },
      "title": "페어 단일 leg 실시간 상태 스냅샷\n(태그 번호는 클라이언트 UI 계약으로 보존됨)"
    },
    "pairLinearBasis": {
      "type": "object",
      "properties": {
        "multiple": {
          "type": "number",
          "format": "double",
          "title": "배율 (예: 1.0, non-zero finite)"
        },
        "basisBid": {
          "type": "string",
          "format": "int64",
          "title": "Bid quote 산출용 basis 오프셋 (원)"
        },
        "basisAsk": {
          "type": "string",
          "format": "int64",
          "title": "Ask quote 산출용 basis 오프셋 (원)"
        }
      },
      "title": "선형 환산 방식",
      "required": [
