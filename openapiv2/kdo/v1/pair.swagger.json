            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pair",
            "description": "리소스 이름 (pairs/{id})",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "pairs/[^/]+"
          },
          {
            "name": "pageSize",
            "description": "페이지 크기 (기본: 50, 최대: 200)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (다음 페이지 조회용)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "orderBy",
            "description": "정렬 기준 (기본: dispatched_at DESC)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "outcome",
            "description": "outcome 필터 (UNSPECIFIED = 전체, 그 외 값이면 해당 outcome만 반환)\n\n - PAIR_EXECUTION_OUTCOME_SUBMITTED: 발주 성공\n - PAIR_EXECUTION_OUTCOME_SKIPPED_PRE_VALIDATION: 사전 검증 실패로 스킵\n - PAIR_EXECUTION_OUTCOME_SKIPPED_COOLDOWN: 쿨다운 중 스킵\n - PAIR_EXECUTION_OUTCOME_SKIPPED_NO_PRECOMPUTED: 사전 계산 없음으로 스킵\n - PAIR_EXECUTION_OUTCOME_PARTIAL_FAILURE: 한쪽만 발주 성공 (부분 실패)\n - PAIR_EXECUTION_OUTCOME_FAILED: 전체 실패\n - PAIR_EXECUTION_OUTCOME_SKIPPED_NO_FILLED: 체결 수량 없음으로 스킵 (filled qty = 0)",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "PAIR_EXECUTION_OUTCOME_UNSPECIFIED",
              "PAIR_EXECUTION_OUTCOME_SUBMITTED",
              "PAIR_EXECUTION_OUTCOME_SKIPPED_PRE_VALIDATION",
              "PAIR_EXECUTION_OUTCOME_SKIPPED_COOLDOWN",
              "PAIR_EXECUTION_OUTCOME_SKIPPED_NO_PRECOMPUTED",
              "PAIR_EXECUTION_OUTCOME_PARTIAL_FAILURE",
              "PAIR_EXECUTION_OUTCOME_FAILED",
              "PAIR_EXECUTION_OUTCOME_SKIPPED_NO_FILLED"
            ],
            "default": "PAIR_EXECUTION_OUTCOME_UNSPECIFIED"
          }
        ],
        "tags": [
          "PairService"
        ]
      }
    },
