        ]
      }
    },
    "/v1/{pair.name}": {
      "patch": {
        "summary": "Pair 수정",
        "operationId": "PairService_UpdatePair",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/pairPair"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pair.name",
            "description": "리소스 이름 (pairs/{id})",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "pairs/[^/]+"
          },
          {
            "name": "pair",
            "description": "수정할 Pair",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int32",
                  "title": "Pair ID",
                  "readOnly": true
                },
                "displayName": {
                  "type": "string",
                  "title": "전략 이름 (고유)"
                },
                "portfolioId": {
                  "type": "integer",
                  "format": "int32",
                  "title": "Portfolio ID"
                },
                "base": {
                  "$ref": "#/definitions/pairPairEntry",
                  "title": "Base 엔트리"
                },
                "counter": {
                  "$ref": "#/definitions/pairPairEntry",
                  "title": "Counter 엔트리"
                },
                "status": {
                  "$ref": "#/definitions/pairPairStatus",
                  "title": "상태",
                  "readOnly": true
                },
                "createTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "생성 시간",
                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "수정 시간",
                  "readOnly": true
                },
                "trigger": {
                  "$ref": "#/definitions/v1pairTriggerCondition",
                  "description": "트리거 — 언제 발사할지. 실행(execution)과 독립적으로 조합한다."
                },
                "execution": {
                  "$ref": "#/definitions/pairOrderExecution",
                  "description": "실행 — 발사 시 무엇을 할지. 트리거(trigger)와 독립적으로 조합한다."
                },
                "nav": {
                  "$ref": "#/definitions/v1pairNav",
                  "description": "ETF↔Future NAV 환산 설정 — TargetNavQuantityImbalance 트리거·MakeCounterIocBalance/CounterBepScalp\nexecution 이 공유. NAV 미사용 페어는 미설정."
                }
              },
              "title": "수정할 Pair",
              "required": [
                "displayName",
                "portfolioId",
                "base",
                "counter"
              ]
            }
          }
        ],
        "tags": [
          "PairService"
        ]
      }
    },
