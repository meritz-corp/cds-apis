          "format": "int64",
          "title": "base + counter 누적 발주 수량"
        },
        "totalFilled": {
          "type": "string",
          "format": "int64",
          "title": "base + counter 누적 체결 수량"
        },
        "executionCount": {
          "type": "string",
          "format": "int64",
          "title": "발주 성공 횟수"
        },
        "realizedPnl": {
          "type": "string",
          "format": "int64",
          "description": "실현 손익 (milli-won). 현재 메모리 카운터 기반."
        }
      },
      "title": "페어 누적 통계 스냅샷 (인메모리 카운터 기반)"
    },
    "pairPairStatus": {
      "type": "string",
      "enum": [
        "PAIR_STATUS_UNSPECIFIED",
        "PAIR_STATUS_ACTIVE",
        "PAIR_STATUS_PAUSED",
        "PAIR_STATUS_ARCHIVED"
      ],
      "default": "PAIR_STATUS_UNSPECIFIED",
      "description": "- PAIR_STATUS_ACTIVE: 운영 중 (hot loop 동작)\n - PAIR_STATUS_PAUSED: 일시 중지\n - PAIR_STATUS_ARCHIVED: 보관 (더 이상 사용 안 함)",
      "title": "Pair 상태"
    },
    "pairPairStatusUpdate": {
      "type": "object",
      "properties": {
        "pair": {
          "type": "string",
          "title": "리소스 이름 (pairs/{id})"
        },
        "base": {
          "$ref": "#/definitions/pairFillStatus",
          "title": "Base 슬롯 상태"
        },
        "counter": {
          "$ref": "#/definitions/pairFillStatus",
          "title": "Counter 슬롯 상태"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "title": "스냅샷 시각"
        },
        "exit": {
          "$ref": "#/definitions/pairFillStatus",
          "description": "exit(청산) 슬롯 상태 — CounterIocTpSl round-trip 전용.\nbase+counter 실행(BaseMakeCounterIoc 등)은 0으로 채워짐."
        }
      },
      "title": "StreamPairStatus 스트리밍 응답 — 페어 상태 스냅샷"
    },
    "pairTargetNavQuantityImbalanceTrigger": {
      "type": "object",
      "properties": {
        "thresholdRatio": {
          "type": "number",
          "format": "double",
          "title": "수량 불균형 임계 (BestMakeQuantityImbalanceTrigger 와 동일 판정식)"
        },
        "cooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "트리거 후 재트리거까지 대기시간 (ms)"
        },
        "imbalanceSymbol": {
          "type": "string",
          "description": "qty imbalance 판정 전용 심볼 (미지정=base.symbol 동일, 기존 동작).\n지정 시 해당 호가(예: 현물)의 deficit_side 로 qty_gate 평가. price_gate(NAV 비교)와 주문 발주는 base 유지."
        },
        "minBaseQty": {
          "type": "string",
          "format": "int64",
          "description": "base 의 bid·ask 1호가 수량이 모두 이 값을 초과해야 트리거 발사. 0 = 미설정."
        }
      },
      "description": "counter 시세로 base 의 NAV 목표가를 환산해, base 자기측(BestMake) 1호가가\n목표가와 정확히 일치하면서 수량 불균형일 때 발사. nav 파라미터는 Pair.nav 공유 설정 사용."
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1pairNav": {
      "type": "object",
      "properties": {
        "navKind": {
          "$ref": "#/definitions/pairEtfNavKind"
        },
        "basis": {
          "type": "string",
          "format": "int64",
          "description": "NAV 베이시스 (선물 가격 축, base=선물 기준 단일값).\n양수면 선물 목표가를 보수적으로 조정."
        },
        "basisSubscribeEnabled": {
          "type": "boolean",
          "description": "선물-ETF basis 동기화 버스 구독 여부.\ntrue 이면 pair가 버스 이벤트를 수신해 Nav.basis를 자동 갱신한다. 기본 false."
        }
      },
      "description": "ETF↔Future 페어의 NAV 환산 설정 — 트리거(TargetNav)와 실행(counter BEP)이 공유.\nbase/counter 중 한쪽이 ETF, 다른쪽이 Future 여야 한다 (방향 무관)."
    },
    "v1pairPriceSource": {
      "type": "string",
      "enum": [
        "PRICE_SOURCE_UNSPECIFIED",
        "PRICE_SOURCE_BEST_MAKE",
        "PRICE_SOURCE_BEST_TAKE"
      ],
      "default": "PRICE_SOURCE_UNSPECIFIED",
      "description": "참조 가격 소스 (entry.side 기준 자기/상대 호가).\n\n - PRICE_SOURCE_BEST_MAKE: 자기호가 (entry.side 와 같은 방향의 1호가). Bid 주문 → bid1, Ask 주문 → ask1.\n - PRICE_SOURCE_BEST_TAKE: 상대호가 (entry.side 반대 방향의 1호가). Bid 주문 → ask1, Ask 주문 → bid1."
    },
    "v1pairTriggerCondition": {
      "type": "object",
      "properties": {
        "bestMakeQuantityImbalance": {
          "$ref": "#/definitions/pairBestMakeQuantityImbalanceTrigger",
          "description": "base 자기측(BestMake) 1호가 수량 불균형 트리거. base.side 가 담당 deficit 방향."
        },
        "targetNavQuantityImbalance": {
          "$ref": "#/definitions/pairTargetNavQuantityImbalanceTrigger",
          "description": "counter 시세로 base 의 NAV 목표가를 환산해, base 자기측(BestMake) 1호가가\n목표가와 정확히 일치하면서 수량 불균형일 때 발사. nav 파라미터는 Pair.nav 공유 설정 사용."
        }
      },
      "description": "트리거 — 언제 발사할지. 실행(OrderExecution)과 독립적으로 조합한다."
    }
  }
}
