          "title": "taker(헷지) 측 주문 유형"
        }
      },
      "title": "PricingMakerTaker 모드 설정",
      "required": [
        "makerLeg",
        "pricing"
      ]
    },
    "pairRetickPolicy": {
      "type": "object",
      "properties": {
        "tickThreshold": {
          "type": "integer",
          "format": "int32",
          "title": "fair 가격이 이 tick 수 이상 이동해야 정정 (1 이상)"
        },
        "amendCooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "직전 정정으로부터 이만큼 경과해야 다음 정정 허용 (ms)"
        },
        "cancelOnStop": {
          "type": "boolean",
          "title": "stop 시 미체결 maker 주문 자동 취소 여부"
        }
      },
      "title": "maker 정정(amend) 정책"
    },
    "pairSimultaneousCompare": {
      "type": "object",
      "properties": {
        "condition": {
          "$ref": "#/definitions/pairPairCondition",
          "title": "가격 비교 조건"
        },
        "orderType": {
          "$ref": "#/definitions/pairPairOrderType",
          "title": "주문 유형"
        },
        "cooldownMs": {
          "type": "string",
          "format": "uint64",
          "title": "트리거 후 재트리거까지 대기시간 (ms)"
        },
        "applyTickOffset": {
          "type": "boolean",
          "title": "hit 직후 지정가 조정 여부"
        }
      },
      "title": "SimultaneousCompare 모드 설정"
    },
    "pairSpreadDirection": {
      "type": "string",
      "enum": [
        "SPREAD_DIRECTION_UNSPECIFIED",
        "SPREAD_DIRECTION_BASE_HIGH",
        "SPREAD_DIRECTION_COUNTER_HIGH",
        "SPREAD_DIRECTION_BOTH"
      ],
      "default": "SPREAD_DIRECTION_UNSPECIFIED",
      "description": "- SPREAD_DIRECTION_BASE_HIGH: Base가 비쌀 때만 트리거\n - SPREAD_DIRECTION_COUNTER_HIGH: Counter가 비쌀 때만 트리거\n - SPREAD_DIRECTION_BOTH: 양방향",
      "title": "스프레드 방향 (어느 쪽이 비쌀 때 트리거할지)"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1pairEtfNav": {
      "type": "object",
      "properties": {
        "pricingKind": {
          "$ref": "#/definitions/pairEtfNavKind",
          "title": "NAV 계산 공식 종류"
        },
        "direction": {
          "$ref": "#/definitions/pairNavDirection",
          "title": "환산 방향 (Inverse: pricer=ETF→maker=선물, Forward: pricer=선물→maker=ETF)"
        },
        "ctx": {
          "$ref": "#/definitions/pairPricingContextSnapshot",
          "title": "정적 pricing 파라미터 snapshot"
        },
        "bidBasis": {
          "type": "string",
          "format": "int64",
          "title": "Bid quote 산출용 basis (원, raw int64)"
        },
        "askBasis": {
          "type": "string",
          "format": "int64",
          "title": "Ask quote 산출용 basis (원, raw int64)"
        },
        "linearFallbackMultiplier": {
          "type": "number",
          "format": "double",
          "title": "PDF/Pdf fallback용 선형 배율 (inverse 모드, 기본 1.0)"
        },
        "prevIndex": {
          "type": "string",
          "format": "int64",
          "title": "FutureBasis/LeverageFuture variant의 전일 기초지수 가격 (원, raw int64)\nEtfNavKind가 FUTURE_BASIS 또는 LEVERAGE_FUTURE일 때 필수"
        },
        "prevFuture": {
          "type": "string",
          "format": "int64",
          "title": "LeverageFuture variant의 전일 선물 가격 (원, raw int64)\nEtfNavKind가 LEVERAGE_FUTURE일 때 필수"
        }
      },
      "title": "ETF NAV 기반 환산 방식",
      "required": [
        "pricingKind",
        "direction",
        "ctx"
      ]
    },
    "v1pairPriceSource": {
      "type": "string",
      "enum": [
        "PRICE_SOURCE_UNSPECIFIED",
        "PRICE_SOURCE_MID_PRICE",
        "PRICE_SOURCE_LAST_PRICE",
        "PRICE_SOURCE_BEST_BID",
        "PRICE_SOURCE_BEST_ASK"
      ],
      "default": "PRICE_SOURCE_UNSPECIFIED",
      "description": "- PRICE_SOURCE_MID_PRICE: 중간가 (Bid1 + Ask1) / 2\n - PRICE_SOURCE_LAST_PRICE: 직전 체결가\n - PRICE_SOURCE_BEST_BID: 최우선 매수호가\n - PRICE_SOURCE_BEST_ASK: 최우선 매도호가",
      "title": "참조 가격 소스"
    },
    "v1pairSpreadAmountCondition": {
      "type": "object",
      "properties": {
        "threshold": {
          "type": "string",
          "format": "int64",
          "title": "스프레드 임계값 (원, 1 이상)"
        },
        "direction": {
          "$ref": "#/definitions/pairSpreadDirection",
          "title": "트리거 방향"
        }
      },
      "title": "절대 스프레드 금액 조건 (|base - counter| \u003e= threshold)",
      "required": [
        "threshold",
        "direction"
      ]
    },
    "v1pairSpreadBpsCondition": {
      "type": "object",
      "properties": {
        "thresholdBps": {
          "type": "number",
          "format": "double",
          "title": "스프레드 임계값 (bps, 1bp = 0.01%)"
        },
        "direction": {
          "$ref": "#/definitions/pairSpreadDirection",
          "title": "트리거 방향"
        }
      },
      "title": "상대 스프레드 (bps) 조건 (|spread| / mid * 10000 \u003e= threshold_bps, base 기준)",
      "required": [
        "thresholdBps",
        "direction"
      ]
    }
  }
}
