        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "title": "FitToMarket"
            }
          }
        ],
