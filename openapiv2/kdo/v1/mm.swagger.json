  "definitions": {
    "mmCreateMarketMakingRequest": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ISIN 심볼"
        },
        "config": {
          "$ref": "#/definitions/mmMarketMakingConfiguration",
          "title": "MM 설정"
        }
      },
      "title": "CreateMarketMaking",
      "required": [
        "symbol",
        "config"
      ]
    },
    "mmExposureGuardState": {
      "type": "object",
      "properties": {
        "netExposure": {
          "type": "string",
          "format": "int64",
          "title": "현재 순노출 수량"
        },
        "bidScale": {
          "type": "number",
          "format": "double",
          "title": "현재 bid 수량 스케일 (0.0 ~ 1.0)"
        },
        "askScale": {
          "type": "number",
          "format": "double",
          "title": "현재 ask 수량 스케일 (0.0 ~ 1.0)"
        }
      },
      "title": "순노출 guard 런타임 상태"
    },
    "mmInventoryBalancerState": {
      "type": "object",
      "properties": {
        "netFlow": {
          "type": "string",
          "format": "int64",
          "title": "현재 누적 순매매 흐름"
        },
        "priceShiftTicks": {
          "type": "integer",
          "format": "int32",
          "title": "현재 가격 중심 이동 틱 수"
        },
        "bidScale": {
          "type": "number",
          "format": "double",
          "title": "현재 bid 수량 스케일 (0.0 ~ 1.0)"
        },
        "askScale": {
          "type": "number",
          "format": "double",
          "title": "현재 ask 수량 스케일 (0.0 ~ 1.0)"
        }
      },
      "title": "InventoryBalancer 런타임 상태"
    },
    "mmListMarketMakingResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/mmMarketMaking"
          },
          "title": "등록된 MM 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "mmMarketMaking": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ISIN 심볼"
        },
        "state": {
          "$ref": "#/definitions/mmMarketMakingState",
          "title": "현재 상태"
        },
        "config": {
          "$ref": "#/definitions/mmMarketMakingConfiguration",
          "title": "MM 설정"
        },
        "fundCode": {
          "type": "string",
          "title": "펀드 코드"
        },
        "tickSize": {
          "type": "string",
          "format": "int64",
          "title": "ETF tick size (Price internal representation)"
        }
      },
      "title": "MM 심볼 정보"
    },
    "mmMarketMakingConfiguration": {
      "type": "object",
      "properties": {
        "pricing": {
          "type": "string",
          "title": "Pricing 전략: \"plain_follow\", \"mean_bidask\", \"nav\", \"krx_nav\""
        },
        "skew": {
          "$ref": "#/definitions/mmMarketMakingSkew",
          "title": "Skew 설정"
        },
        "tradeAnalyzer": {
          "$ref": "#/definitions/mmMarketMakingTradeAnalyzer",
          "title": "Trade Analyzer 설정"
        },
        "screening": {
          "$ref": "#/definitions/mmMarketMakingScreening",
          "title": "Screening 설정"
        },
        "enabled": {
          "type": "boolean",
          "title": "MM 활성화 여부"
        },
        "momentum": {
          "$ref": "#/definitions/mmMarketMakingMomentum",
          "title": "Momentum 설정 (최근 가격 흐름 → bid/ask 조정)"
        },
        "exposureGuard": {
          "$ref": "#/definitions/mmMarketMakingExposureGuard",
          "title": "순노출 hard limit 제어 설정"
        },
        "inventoryBalancer": {
          "$ref": "#/definitions/mmMarketMakingInventoryBalancer",
          "title": "중기 buy/sell imbalance 복원 설정"
        },
        "bidAdjustment": {
          "type": "string",
          "format": "int64",
          "title": "기준가격 대비 bid 조정값 (Price internal representation)"
        },
        "askAdjustment": {
          "type": "string",
          "format": "int64",
          "title": "기준가격 대비 ask 조정값 (Price internal representation)"
        }
      },
      "title": "MM 엔진 설정 (MmConfig 대응)"
    },
    "mmMarketMakingExposureGuard": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "reduceStartMultiple": {
          "type": "integer",
          "format": "int32",
          "title": "이 배수부터 같은 방향 수량을 줄이기 시작한다"
        },
        "maxInventoryMultiple": {
          "type": "integer",
          "format": "int32",
          "title": "이 배수에 도달하면 같은 방향 호가 수량을 0으로 clamp 한다"
        }
      },
      "title": "순노출 hard limit 제어 설정"
    },
    "mmMarketMakingInventoryBalancer": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "triggerMultiple": {
          "type": "integer",
          "format": "int32",
          "title": "imbalance가 이 배수만큼 쌓이면 복원 로직이 발동한다"
        },
        "priceSkewTicks": {
          "type": "integer",
          "format": "int32",
          "title": "단계당 가격 중심 이동 틱 수"
        },
        "sameSideReduction": {
          "type": "number",
          "format": "double",
          "title": "단계당 같은 방향 수량 축소 비율 (0.0 ~ 1.0)"
        },
        "minSameSideScale": {
          "type": "number",
          "format": "double",
          "title": "같은 방향 수량의 최소 비율"
        }
      },
      "title": "중기 buy/sell imbalance 복원 설정"
    },
    "mmMarketMakingMomentum": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "windowMs": {
          "type": "string",
          "format": "uint64",
          "title": "최근 가격 샘플을 유지할 시간 창 (ms)"
        },
        "triggerTicks": {
          "type": "integer",
          "format": "int32",
          "title": "연속 모멘텀 강도를 정규화할 기준 틱 수"
        },
        "followSensitivity": {
          "type": "number",
          "format": "double",
          "title": "정규화된 모멘텀 강도를 bid 추종 틱으로 바꾸는 민감도"
        },
        "escapeSensitivity": {
          "type": "number",
          "format": "double",
          "title": "정규화된 모멘텀 강도를 ask/bid 도망 틱으로 바꾸는 민감도"
        },
        "maxFollowTicks": {
          "type": "integer",
          "format": "int32",
          "title": "bid 추종 최대 틱 수"
        },
        "maxEscapeTicks": {
          "type": "integer",
          "format": "int32",
          "title": "ask/bid 도망 최대 틱 수"
        },
        "isOpposite": {
          "type": "boolean",
          "title": "인버스 방향으로 해석할지 여부"
        }
      },
      "title": "Momentum 설정"
    },
    "mmMarketMakingOrderbookData": {
      "type": "object",
      "properties": {
        "bidPrices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "매수 호가 목록 (string 표현)"
        },
        "askPrices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "매도 호가 목록 (string 표현)"
        },
        "bidQuantities": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "매수 수량 목록"
        },
        "askQuantities": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "매도 수량 목록"
        }
      },
