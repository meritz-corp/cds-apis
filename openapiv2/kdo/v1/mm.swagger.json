{
  "swagger": "2.0",
  "info": {
    "title": "kdo/v1/mm.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "MarketMakingService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/mm": {
      "get": {
        "summary": "MM 목록 조회",
        "operationId": "MarketMakingService_ListMarketMaking",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmListMarketMakingResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional)",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}": {
      "get": {
        "summary": "MM 단일 심볼 조회",
        "operationId": "MarketMakingService_GetMarketMaking",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmMarketMaking"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      },
      "patch": {
        "summary": "MM 설정 업데이트 (DB 저장)",
        "operationId": "MarketMakingService_UpdateMarketMaking",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmMarketMaking"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "config": {
                  "$ref": "#/definitions/mmMarketMakingConfiguration",
                  "title": "업데이트할 MM 설정"
                }
              },
              "title": "UpdateMarketMaking",
              "required": [
                "config"
              ]
            }
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/config": {
      "patch": {
        "summary": "MM 설정 업데이트",
        "operationId": "MarketMakingService_UpdateMarketMakingConfig",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmMarketMakingConfiguration"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "config": {
                  "$ref": "#/definitions/mmMarketMakingConfiguration",
                  "description": "업데이트할 설정 (전체 교체)\npricing, fund_code, tick_size, depth 필드는 read-only이며 무시됩니다."
                }
              },
              "description": "UpdateMarketMakingConfig\nNOTE: config 내 pricing, fund_code, tick_size, depth 필드는 이 요청으로 변경할 수 없습니다.\n해당 필드들은 서버에서 무시됩니다.",
              "required": [
                "config"
              ]
            }
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/engine-state:stream": {
      "get": {
        "summary": "MM 엔진 런타임 상태 실시간 스트리밍",
        "operationId": "MarketMakingService_StreamMmStateUpdate",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/mmMmStateUpdate"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of mmMmStateUpdate"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼 (빈 문자열이면 전체 스트리밍)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/orderbook": {
      "get": {
        "summary": "MM 전용 주문장 조회",
        "operationId": "MarketMakingService_GetMarketMakingOrderbook",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmMarketMakingOrderbookData"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/orderbook:stream": {
      "get": {
        "summary": "MM 전용 주문장 실시간 스트리밍 (서버→클라이언트)",
        "operationId": "MarketMakingService_StreamMarketMakingOrderbook",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/mmMarketMakingOrderbookData"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of mmMarketMakingOrderbookData"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}:start": {
      "post": {
        "summary": "MM 시작 (심볼 등록)",
        "operationId": "MarketMakingService_StartMarketMaking",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmStartMarketMakingResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "config": {
                  "$ref": "#/definitions/mmMarketMakingConfiguration",
                  "title": "MM 설정 오버라이드 (optional, 없으면 기본 설정 사용)"
                }
              },
              "title": "StartMarketMaking"
            }
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}:stop": {
      "post": {
        "summary": "MM 중지 (심볼 해제)",
        "operationId": "MarketMakingService_StopMarketMaking",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmStopMarketMakingResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "title": "StopMarketMaking"
            }
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    }
  },
  "definitions": {
    "commonEtfPricing": {
      "type": "object",
      "properties": {
        "pdfNavHedge": {
          "$ref": "#/definitions/commonPdfNavHedgePricing",
          "title": "분해 헷지 방식"
        },
        "indexTrackingHedge": {
          "$ref": "#/definitions/commonIndexTrackingHedgePricing",
          "title": "선물 헷지 방식"
        },
        "futureBasis": {
          "$ref": "#/definitions/commonFutureBasis"
        },
        "leverageFuture": {
          "$ref": "#/definitions/commonLeverageFuturePricing",
          "title": "레버리지 선물 방식"
        },
        "pdfDecomposeHedge": {
          "$ref": "#/definitions/commonPdfDecomposeHedgePricing",
          "title": "PDF 재귀 분해 헷지 방식: leaf가 단일 종목으로 귀결되는 ETF에 대한 프라이싱"
        }
      },
      "title": "ETF 가격 산출 방식"
    },
    "commonFutureBasis": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "string"
        }
      }
    },
    "commonIndexTrackingHedgePricing": {
      "type": "object",
      "title": "선물 헷지 가격 산출"
    },
    "commonLeverageFuturePricing": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "number",
          "format": "double",
          "title": "기초지수 전일종가"
        },
        "prevFuture": {
          "type": "number",
          "format": "double",
          "title": "선물 전일종가"
        }
      },
      "title": "레버리지 선물 가격 산출"
    },
    "commonPdfDecomposeHedgePricing": {
      "type": "object",
      "description": "PDF 재귀 분해 헷지 가격 산출 (파라미터 없음)\nNAV 계산은 Etf.decomposed_constituents를 PdfNavHedge와 동일 공식으로 적용."
    },
    "commonPdfNavHedgePricing": {
      "type": "object",
      "title": "분해 헷지 가격 산출 (추가 파라미터 없음)"
    },
    "mmExposureBalancerState": {
      "type": "object",
      "properties": {
        "netExposure": {
          "type": "string",
          "format": "int64",
          "title": "현재 순노출 수량"
        },
        "priceShiftTicks": {
          "type": "integer",
          "format": "int32",
          "title": "현재 가격 중심 이동 틱 수"
        },
        "bidScale": {
          "type": "number",
          "format": "double",
          "title": "현재 bid 수량 스케일 (0.0 ~ 1.0)"
        },
        "askScale": {
          "type": "number",
          "format": "double",
          "title": "현재 ask 수량 스케일 (0.0 ~ 1.0)"
        }
      },
      "title": "순노출 및 재고 균형 런타임 상태 (ExposureGuard + InventoryBalancer 통합)"
    },
    "mmKrxNav": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "string",
          "format": "int64",
          "title": "이전 지수 (Price internal representation)"
        },
        "prevFuture": {
          "type": "string",
          "format": "int64",
          "title": "이전 선물 (Price internal representation)"
        }
      },
      "title": "EtfPricing::LeverageFuture { prev_index, prev_future }"
    },
    "mmListMarketMakingResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/mmMarketMaking"
          },
          "title": "등록된 MM 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "mmMarketMaking": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ISIN 심볼"
        },
        "state": {
          "$ref": "#/definitions/mmMarketMakingState",
          "title": "현재 상태"
        },
        "config": {
          "$ref": "#/definitions/mmMarketMakingConfiguration",
          "title": "MM 설정"
        },
        "fundCode": {
          "type": "string",
          "title": "펀드 코드"
        },
        "tickSize": {
          "type": "string",
          "format": "int64",
          "title": "ETF tick size (Price internal representation)"
        }
      },
      "title": "MM 심볼 정보"
    },
    "mmMarketMakingConfiguration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "MM 활성화 여부"
        },
        "pricing": {
          "$ref": "#/definitions/mmMarketMakingPricing",
          "title": "NAV pricing 상세 설정 (pricing = \"nav\" 일 때 사용)"
        },
        "tradeAnalyzer": {
          "$ref": "#/definitions/mmMarketMakingTradeAnalyzer",
          "title": "Trade Analyzer 설정"
        },
        "momentum": {
          "$ref": "#/definitions/mmMarketMakingMomentum",
          "title": "Momentum 설정 (최근 가격 흐름 → bid/ask 조정)"
        },
        "exposureBalancer": {
          "$ref": "#/definitions/mmMarketMakingExposureBalancer",
          "title": "통합 포지션 관리 설정"
        },
        "bidAdjustment": {
          "type": "string",
          "format": "int64",
          "title": "기준가격 대비 bid 조정값 (Price internal representation)"
        },
        "askAdjustment": {
          "type": "string",
          "format": "int64",
          "title": "기준가격 대비 ask 조정값 (Price internal representation)"
        },
        "bidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "레벨당 매수 수량"
        },
        "askQuantity": {
          "type": "string",
          "format": "int64",
          "title": "레벨당 매도 수량"
        },
        "bidBasis": {
          "type": "string",
          "format": "int64",
          "title": "NAV 계산용 bid basis (Price internal representation)"
        },
        "askBasis": {
          "type": "string",
          "format": "int64",
          "title": "NAV 계산용 ask basis (Price internal representation)"
        },
        "bidOffset": {
          "type": "string",
          "format": "int64",
          "title": "NAV+adj 기준가 대비 bid 추가 gap (Price internal representation)"
        },
        "askOffset": {
          "type": "string",
          "format": "int64",
          "title": "NAV+adj 기준가 대비 ask 추가 gap (Price internal representation)"
        }
      },
      "title": "MM 엔진 설정 (MmConfig 대응)"
    },
    "mmMarketMakingExposureBalancer": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "triggerMultiple": {
          "type": "integer",
          "format": "int32",
          "title": "soft zone: 이 배수부터 soft rebalance 발동"
        },
        "priceSkewTicks": {
          "type": "integer",
          "format": "int32",
          "title": "단계당 가격 중심 이동 틱 수"
        },
        "limitMultiple": {
          "type": "integer",
          "format": "int32",
          "title": "hard zone: 이 배수에서 같은 방향 수량 0 (구 hard_limit_max 대체)"
        }
      },
      "title": "통합 포지션 관리 설정 (soft rebalance + hard limit)"
    },
    "mmMarketMakingMomentum": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "windowMs": {
          "type": "string",
          "format": "uint64",
          "title": "최근 가격 샘플을 유지할 시간 창 (ms)"
        },
        "triggerTicks": {
          "type": "integer",
          "format": "int32",
          "title": "연속 모멘텀 강도를 정규화할 기준 틱 수"
        },
        "followSensitivity": {
          "type": "number",
          "format": "double",
          "title": "정규화된 모멘텀 강도를 bid 추종 틱으로 바꾸는 민감도"
        },
        "escapeSensitivity": {
          "type": "number",
          "format": "double",
          "title": "정규화된 모멘텀 강도를 ask/bid 도망 틱으로 바꾸는 민감도"
        },
        "maxFollowTicks": {
          "type": "integer",
          "format": "int32",
          "title": "bid 추종 최대 틱 수"
        },
        "maxEscapeTicks": {
          "type": "integer",
          "format": "int32",
          "title": "ask/bid 도망 최대 틱 수"
        },
        "isOpposite": {
          "type": "boolean",
          "title": "인버스 방향으로 해석할지 여부"
        }
      },
      "title": "Momentum 설정"
    },
    "mmMarketMakingOrderbookData": {
      "type": "object",
      "properties": {
        "bidPrices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "매수 호가 목록 (string 표현)"
        },
        "askPrices": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "매도 호가 목록 (string 표현)"
        },
        "bidQuantities": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "매수 수량 목록"
        },
        "askQuantities": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "매도 수량 목록"
        }
      },
      "title": "MM 전용 주문장 데이터"
    },
    "mmMarketMakingPricing": {
      "type": "object",
      "properties": {
        "plainFollow": {
          "$ref": "#/definitions/mmPlainFollow",
          "title": "PDF 기반 nav 계산 및 헷지 프라이싱"
        },
        "meanBidAsk": {
          "$ref": "#/definitions/mmMeanBidAsk",
          "title": "지수 추종 헷지 프라이싱"
        },
        "nav": {
          "$ref": "#/definitions/mmNav",
          "title": "선물 베이시스 기반 프라이싱"
        },
        "krxNav": {
          "$ref": "#/definitions/mmKrxNav",
          "title": "레버리지 선물 기반 프라이싱"
        }
      },
      "title": "NAV pricing 상세 설정"
    },
    "mmMarketMakingState": {
      "type": "string",
      "enum": [
        "MARKET_MAKING_STATE_UNSPECIFIED",
        "MARKET_MAKING_STATE_IDLE",
        "MARKET_MAKING_STATE_RUNNING"
      ],
      "default": "MARKET_MAKING_STATE_UNSPECIFIED",
      "description": "- MARKET_MAKING_STATE_IDLE: 대기\n - MARKET_MAKING_STATE_RUNNING: 활성",
      "title": "MM 상태"
    },
    "mmMarketMakingTradeAnalyzer": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "활성화 여부"
        },
        "window": {
          "type": "integer",
          "format": "int64",
          "title": "분석 윈도우 크기"
        },
        "ratioThreshold": {
          "type": "number",
          "format": "double",
          "title": "Adverse fill ratio 임계값"
        },
        "strengthThreshold": {
          "type": "number",
          "format": "double",
