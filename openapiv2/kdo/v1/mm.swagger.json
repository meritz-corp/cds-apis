        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      },
      "patch": {
        "summary": "MM 설정 업데이트 (DB 저장)",
        "operationId": "MarketMakingService_UpdateMarketMaking",
        "responses": {
          "200": {
            "description": "A successful response.",
