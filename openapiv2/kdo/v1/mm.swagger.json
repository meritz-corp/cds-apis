  "definitions": {
    "commonEtfPricing": {
      "type": "object",
      "properties": {
        "pdfNavHedge": {
          "$ref": "#/definitions/commonPdfNavHedgePricing",
          "title": "분해 헷지 방식"
        },
        "indexTrackingHedge": {
          "$ref": "#/definitions/commonIndexTrackingHedgePricing",
          "title": "선물 헷지 방식"
        },
        "futureBasis": {
          "$ref": "#/definitions/commonFutureBasis"
        },
        "leverageFuture": {
          "$ref": "#/definitions/commonLeverageFuturePricing",
          "title": "레버리지 선물 방식"
        },
        "pdfDecomposeHedge": {
          "$ref": "#/definitions/commonPdfDecomposeHedgePricing",
          "title": "PDF 재귀 분해 헷지 방식: leaf가 단일 종목으로 귀결되는 ETF에 대한 프라이싱"
        }
      },
      "title": "ETF 가격 산출 방식"
    },
    "commonFutureBasis": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "string"
        }
      }
    },
    "commonIndexTrackingHedgePricing": {
      "type": "object",
      "title": "선물 헷지 가격 산출"
    },
    "commonLeverageFuturePricing": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "number",
          "format": "double",
          "title": "기초지수 전일종가"
        },
        "prevFuture": {
          "type": "number",
          "format": "double",
          "title": "선물 전일종가"
        }
      },
      "title": "레버리지 선물 가격 산출"
    },
    "commonPdfDecomposeHedgePricing": {
      "type": "object",
      "description": "PDF 재귀 분해 헷지 가격 산출 (파라미터 없음)\nNAV 계산은 Etf.decomposed_constituents를 PdfNavHedge와 동일 공식으로 적용."
    },
    "commonPdfNavHedgePricing": {
      "type": "object",
      "title": "분해 헷지 가격 산출 (추가 파라미터 없음)"
    },
    "mmClearFitToMarketResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "title": "메시지"
        }
      }
    },
    "mmExposureBalancerState": {
      "type": "object",
      "properties": {
        "netExposure": {
          "type": "string",
          "format": "int64",
          "title": "현재 순노출 수량"
        },
        "bidScale": {
          "type": "number",
          "format": "double",
          "title": "현재 bid 수량 스케일 (0.0 ~ 1.0)"
        },
        "askScale": {
          "type": "number",
          "format": "double",
          "title": "현재 ask 수량 스케일 (0.0 ~ 1.0)"
        },
        "priceShift": {
          "type": "number",
          "format": "double",
          "title": "현재 가격 중심 이동량 (원, 소수 가능). -(net/trigger_quantity) × price_skew_unit — limit 에서 saturate"
        }
      },
      "title": "순노출 및 재고 균형 런타임 상태 (ExposureGuard + InventoryBalancer 통합)"
    },
    "mmFitToMarketResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "title": "메시지"
        }
      }
    },
    "mmKrxNav": {
      "type": "object",
      "properties": {
        "prevIndex": {
          "type": "string",
          "format": "int64",
          "title": "이전 지수 (Price internal representation)"
        },
        "prevFuture": {
          "type": "string",
          "format": "int64",
          "title": "이전 선물 (Price internal representation)"
        }
      },
      "title": "EtfPricing::LeverageFuture { prev_index, prev_future }"
    },
    "mmListMarketMakingResponse": {
      "type": "object",
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/mmMarketMaking"
          },
          "title": "등록된 MM 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "mmMarketBiasState": {
      "type": "object",
      "properties": {
        "accumulatedBias": {
          "type": "string",
          "format": "int64",
          "title": "누적 영구 편향 (가격 단위, Price internal representation)"
        },
        "lastScore": {
          "type": "integer",
          "format": "int32",
          "title": "마지막 평가 점수 (0~100)"
        },
        "evalCount": {
          "type": "string",
          "format": "int64",
          "title": "누적 평가 횟수"
        }
      },
      "title": "MarketBias 런타임 상태 (갤럭티코 DecoByTradeAcc 포팅)"
    },
    "mmMarketMaking": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "title": "ISIN 심볼"
        },
        "state": {
          "$ref": "#/definitions/mmMarketMakingState",
          "title": "현재 상태"
        },
        "config": {
          "$ref": "#/definitions/mmMarketMakingConfiguration",
          "title": "MM 설정"
        },
        "fundCode": {
          "type": "string",
          "title": "펀드 코드"
        },
        "tickSize": {
          "type": "string",
          "format": "int64",
          "title": "ETF tick size (Price internal representation)"
        }
      },
      "title": "MM 심볼 정보"
    },
    "mmMarketMakingConfiguration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "MM 활성화 여부"
        },
        "pricing": {
          "$ref": "#/definitions/mmMarketMakingPricing",
          "title": "NAV pricing 상세 설정 (pricing = \"nav\" 일 때 사용)"
        },
        "tradeAnalyzer": {
          "$ref": "#/definitions/mmMarketMakingTradeAnalyzer",
          "title": "Trade Analyzer 설정"
        },
        "marketBias": {
          "$ref": "#/definitions/mmMarketMakingMarketBias",
          "title": "MarketBias 설정 (장기 시장 체결 누적 → 영구 skew)"
        },
        "momentum": {
          "$ref": "#/definitions/mmMarketMakingMomentum",
          "title": "Momentum 설정 (단기 시장 체결 비율/강도 → 즉각 bid/ask 동일 shift)"
        },
        "exposureBalancer": {
          "$ref": "#/definitions/mmMarketMakingExposureBalancer",
          "title": "통합 포지션 관리 설정"
        },
        "bidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "레벨당 매수 수량"
        },
        "askQuantity": {
          "type": "string",
          "format": "int64",
          "title": "레벨당 매도 수량"
        },
        "bidOffset": {
          "type": "string",
          "format": "int64",
          "title": "NAV+adj 기준가 대비 bid 추가 gap (Price internal representation)"
        },
        "askOffset": {
          "type": "string",
          "format": "int64",
          "title": "NAV+adj 기준가 대비 ask 추가 gap (Price internal representation)"
        },
        "basis": {
          "type": "string",
          "format": "int64",
          "title": "단일 basis (bid_basis/ask_basis 통합 후속, Price internal representation)"
        },
        "baseHalfTicks": {
          "type": "integer",
          "format": "int32",
          "title": "호가 반폭 (틱 수). bid = mid - half, ask = mid + half"
        },
        "quantityLimit": {
          "$ref": "#/definitions/mmMarketMakingQuantityLimit",
          "title": "순포지션 수량 한도 (방향별 호가 차단)"
        }
      },
      "title": "MM 엔진 설정 (MmConfig 대응)"
    },
    "mmMarketMakingExposureBalancer": {
      "type": "object",
