              "$ref": "#/definitions/mmMarketMaking"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "config": {
                  "$ref": "#/definitions/mmMarketMakingConfiguration",
                  "title": "업데이트할 MM 설정"
                }
              },
              "title": "UpdateMarketMaking",
              "required": [
                "config"
              ]
            }
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/config": {
      "patch": {
        "summary": "MM 설정 업데이트",
        "operationId": "MarketMakingService_UpdateMarketMakingConfig",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/mmMarketMakingConfiguration"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "config": {
                  "$ref": "#/definitions/mmMarketMakingConfiguration",
                  "description": "업데이트할 설정 (전체 교체)\npricing, fund_code, tick_size, depth 필드는 read-only이며 무시됩니다."
                }
              },
              "description": "UpdateMarketMakingConfig\nNOTE: config 내 pricing, fund_code, tick_size, depth 필드는 이 요청으로 변경할 수 없습니다.\n해당 필드들은 서버에서 무시됩니다.",
              "required": [
                "config"
              ]
            }
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/engine-state:stream": {
      "get": {
        "summary": "MM 엔진 런타임 상태 실시간 스트리밍",
        "operationId": "MarketMakingService_StreamMmStateUpdate",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/mmMmStateUpdate"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of mmMmStateUpdate"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼 (빈 문자열이면 전체 스트리밍)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/fills:stream": {
      "get": {
        "summary": "MM 체결 요약 실시간 스트리밍 (당일 누적). 구독 즉시 현재 누적 스냅샷을 1회 내려주고,\n이후 체결마다 갱신된 누적 요약을 emit. MM 전략 자기 체결만 포함 — 같은 심볼의\n타 전략(선물LP 헷지·페어 등) 체결은 제외된다.",
        "operationId": "MarketMakingService_StreamMmFills",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/mmMmFillSummary"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of mmMmFillSummary"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "ISIN 심볼",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "[^/]+"
          },
          {
            "name": "fundCode",
            "description": "펀드 코드 — 같은 심볼을 여러 펀드로 운용할 때 구분용.\n지정 시 해당 (symbol, fund) MM 컨텍스트와 불일치하면 NOT_FOUND.",
            "in": "query",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "MarketMakingService"
        ]
      }
    },
    "/v1/mm/{symbol}/orderbook": {
