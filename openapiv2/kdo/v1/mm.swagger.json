    "mmMarketMakingState": {
      "type": "string",
      "enum": [
        "MARKET_MAKING_STATE_UNSPECIFIED",
        "MARKET_MAKING_STATE_IDLE",
        "MARKET_MAKING_STATE_RUNNING"
      ],
      "default": "MARKET_MAKING_STATE_UNSPECIFIED",
      "description": "- MARKET_MAKING_STATE_IDLE: 대기\n - MARKET_MAKING_STATE_RUNNING: 활성",
      "title": "MM 상태"
    },
    "mmMarketMakingTradeAnalyzer": {
