          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/hedgeUpdateHedgeAccumulatorFilledQuantitiesRequest"
            }
          }
        ],
        "tags": [
          "HedgeService"
        ]
      }
    },
