          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "filter",
            "description": "필터\nAvailable filters:\n* portfolio_id\n  * `equal`\n* fund_code\n  * `equal`\n* source_symbol\n  * `equal`\n\nExamples:\n* filter=fund_code=\"0159\"\n* filter=portfolio_id=1\n빈 문자열 = 전체 accumulator 상태 스트리밍",
            "in": "query",
