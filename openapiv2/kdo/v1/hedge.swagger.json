        "parameters": [
          {
            "name": "hedge.name",
            "description": "리소스 이름 (예: hedges/1)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "hedges/[^/]+"
          },
          {
            "name": "hedge",
            "description": "수정할 헷지 정보",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int32",
                  "title": "Hedge ID",
                  "readOnly": true
                },
                "sourceFundCode": {
                  "type": "string",
                  "title": "소스(원주문) 펀드 코드"
                },
                "sourceSymbol": {
                  "type": "string",
                  "title": "소스 종목 심볼 (체결 감시 대상)"
                },
                "hedgeMethod": {
                  "$ref": "#/definitions/hedgeHedgeMethod",
                  "title": "헷지 방식"
                },
                "isActive": {
                  "type": "boolean",
                  "title": "활성화 여부"
                },
                "createTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "생성 시간",
                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "수정 시간",
                  "readOnly": true
                },
                "execPriceType": {
                  "$ref": "#/definitions/hedgeExecPriceType",
                  "title": "헷지 주문 체결 가격 유형"
                },
                "autoAmend": {
                  "type": "boolean",
                  "title": "자동정정 활성화 여부"
                },
                "amendMethod": {
                  "$ref": "#/definitions/commonAmendMethodType",
                  "title": "자동정정 전략 유형 (auto_amend=true 일 때 유효)\n미지정(UNSPECIFIED) 시 TIMED_MARKET으로 처리됨"
                },
                "filledQuantityPerHedge": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "format": "int64"
                  },
                  "title": "헷지 1주 주문당 소스 종목 체결수량 기준\nkey: 헷지 대상 심볼, value: 소스 종목 체결수량",
                  "readOnly": true
                },
                "hedgeFundCode": {
                  "type": "string",
                  "title": "헷지 주문이 실행되는 펀드 코드"
                }
              },
              "title": "수정할 헷지 정보",
              "required": [
                "sourceFundCode",
                "sourceSymbol",
                "hedgeMethod",
                "hedgeFundCode"
              ]
            }
          }
        ],
        "tags": [
          "HedgeService"
        ]
      }
    },
