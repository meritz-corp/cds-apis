  "definitions": {
    "commonAmendMethodType": {
      "type": "string",
      "enum": [
        "AMEND_METHOD_TYPE_UNSPECIFIED",
        "AMEND_METHOD_TYPE_SELF_QUOTE",
        "AMEND_METHOD_TYPE_STOP_LOSS"
      ],
      "default": "AMEND_METHOD_TYPE_UNSPECIFIED",
      "description": "- AMEND_METHOD_TYPE_UNSPECIFIED: 미지정 (기본값: SELF_QUOTE로 처리)\n - AMEND_METHOD_TYPE_SELF_QUOTE: 셀프쿼팅 정정: 반대편 잔량 비율이 임계값 이상이면 즉시 체결 시도\n - AMEND_METHOD_TYPE_STOP_LOSS: 손절 정정: tick_threshold 이상 불리해지면 시장가로 전환",
      "title": "자동정정 전략 유형"
    },
    "hedgeAmountTrigger": {
      "type": "object",
      "properties": {
        "threshold": {
          "type": "string",
          "format": "int64",
          "title": "트리거 금액 임계값 (원)"
        },
        "hedgeInstrument": {
          "type": "string",
          "title": "헷지 종목 심볼"
        },
        "ratio": {
          "type": "number",
          "format": "double",
          "title": "헷지 비율"
        }
      },
