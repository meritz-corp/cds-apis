  "definitions": {
    "commonAmendMethodType": {
      "type": "string",
      "enum": [
        "AMEND_METHOD_TYPE_UNSPECIFIED",
        "AMEND_METHOD_TYPE_AGGRESSIVE",
        "AMEND_METHOD_TYPE_EVASIVE",
        "AMEND_METHOD_TYPE_BEST_PRICE",
        "AMEND_METHOD_TYPE_STOP_LOSS",
        "AMEND_METHOD_TYPE_TIMED_MARKET"
      ],
      "default": "AMEND_METHOD_TYPE_UNSPECIFIED",
      "description": "- AMEND_METHOD_TYPE_UNSPECIFIED: 미지정 (기본값: TIMED_MARKET으로 처리)\n - AMEND_METHOD_TYPE_AGGRESSIVE: 적극적 정정: 반대편 잔량 비율이 임계값 이상이면 즉시 체결 시도\n - AMEND_METHOD_TYPE_EVASIVE: 회피적 정정: tick_offset 만큼 가격을 조정하여 미체결 유지\n - AMEND_METHOD_TYPE_BEST_PRICE: 최우선 호가: 상대방 최우선 호가로 정정\n - AMEND_METHOD_TYPE_STOP_LOSS: 손절 정정: tick_threshold 이상 불리해지면 시장가로 전환\n - AMEND_METHOD_TYPE_TIMED_MARKET: 시간 제한 시장가: timeout 후 시장가로 전환",
      "title": "자동정정 전략 유형"
    },
    "hedgeAmountTrigger": {
      "type": "object",
      "properties": {
        "threshold": {
          "type": "string",
          "format": "int64",
          "title": "트리거 금액 임계값 (원)"
        },
        "hedgeInstrument": {
          "type": "string",
          "title": "헷지 종목 심볼"
        },
        "ratio": {
          "type": "number",
          "format": "double",
          "title": "헷지 비율"
        }
      },
      "title": "금액 기반 트리거: 순금액 변동이 threshold 이상이면 헷지 실행",
      "required": [
        "threshold",
        "hedgeInstrument",
        "ratio"
      ]
    },
    "hedgeEtfDecompositionHedge": {
      "type": "object",
      "properties": {
        "cu": {
          "type": "integer",
          "format": "int32",
          "title": "1CU(설정단위) 당 ETF 주수"
        },
        "hedgeOrdersPer1cu": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "format": "int32"
          },
          "title": "1CU 당 구성 종목별 헷지 주문 수량\nkey: 종목 심볼, value: 1CU 당 주문 수량"
        }
      },
      "title": "ETF 분해 헷지: ETF를 구성 종목으로 분해하여 CU 단위로 헷지",
      "required": [
        "cu"
      ]
    },
    "hedgeExecPriceType": {
      "type": "string",
      "enum": [
        "EXEC_PRICE_TYPE_UNSPECIFIED",
        "EXEC_PRICE_TYPE_IMMEDIATE_FILL",
        "EXEC_PRICE_TYPE_COUNTER_BEST",
        "EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_1",
        "EXEC_PRICE_TYPE_QUOTED_PRICE",
        "EXEC_PRICE_TYPE_QUOTED_PRICE_MINUS_1",
        "EXEC_PRICE_TYPE_QUOTED_PRICE_MINUS_2",
        "EXEC_PRICE_TYPE_QUOTED_PRICE_MINUS_3",
        "EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_2",
        "EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_3",
        "EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_4",
        "EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_5"
      ],
      "default": "EXEC_PRICE_TYPE_UNSPECIFIED",
      "description": "헷지 주문 체결 가격 유형\n거래소의 구체적인 호가 유형(QuoteType)과 달리,\n헷지 주문의 전략적 의도를 표현합니다.\n\n - EXEC_PRICE_TYPE_UNSPECIFIED: 미지정\n - EXEC_PRICE_TYPE_IMMEDIATE_FILL: 즉시 체결: 조건부지정가(PriceLimitBestTake)로 즉시 체결 시도\n - EXEC_PRICE_TYPE_COUNTER_BEST: 상대호가: 상대방 최우선호가 가격으로 지정가 주문\n - EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_1: 상대호가 +1틱 (공격적: 매수→더 비싸게, 매도→더 싸게)\n - EXEC_PRICE_TYPE_QUOTED_PRICE: 호가 가격: 지정된 호가 가격으로 주문\n - EXEC_PRICE_TYPE_QUOTED_PRICE_MINUS_1: QuotedPrice에서 1틱 더 방어적 (매수: -1틱, 매도: +1틱)\n - EXEC_PRICE_TYPE_QUOTED_PRICE_MINUS_2: QuotedPrice에서 2틱 더 방어적 (매수: -2틱, 매도: +2틱)\n - EXEC_PRICE_TYPE_QUOTED_PRICE_MINUS_3: QuotedPrice에서 3틱 더 방어적 (매수: -3틱, 매도: +3틱)\n - EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_2: 상대호가 +2틱\n - EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_3: 상대호가 +3틱\n - EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_4: 상대호가 +4틱\n - EXEC_PRICE_TYPE_COUNTER_BEST_PLUS_5: 상대호가 +5틱"
    },
    "hedgeFutureHedge": {
      "type": "object",
      "properties": {
        "hedgeSymbol": {
          "type": "string",
          "title": "헷지 대상 종목 심볼"
        },
        "ratio": {
          "type": "number",
          "format": "double",
          "title": "헷지 비율 (소스 수량 대비)"
        }
      },
      "title": "선물 헷지: 소스 종목 체결 시 헷지 종목을 ratio 비율로 반대 매매",
      "required": [
        "hedgeSymbol",
        "ratio"
      ]
    },
    "hedgeHedge": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "리소스 이름 (예: hedges/1)",
          "readOnly": true
        },
        "id": {
