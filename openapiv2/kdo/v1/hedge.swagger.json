            "required": true,
            "type": "string",
            "pattern": "hedgeGroups/[^/]+"
          },
          {
            "name": "hedgeGroup",
            "description": "수정할 헷지그룹 정보",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int32",
                  "title": "HedgeGroup ID",
                  "readOnly": true
                },
                "portfolio": {
                  "type": "string",
                  "title": "포트폴리오 리소스 이름\nformat: portfolios/{portfolio}"
                },
                "displayName": {
                  "type": "string",
                  "title": "그룹 이름"
                },
                "hedgeFundCode": {
                  "type": "string",
                  "title": "헷지 펀드 코드 (헷지 주문 실행 펀드)"
                },
                "triggerCondition": {
                  "$ref": "#/definitions/v1hedgeTriggerCondition",
                  "title": "트리거 조건"
                },
                "isActive": {
                  "type": "boolean",
                  "title": "활성화 여부"
                },
                "createTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "생성 시간",
                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "수정 시간",
                  "readOnly": true
                },
                "separateBySource": {
                  "type": "boolean",
                  "description": "If true, hedge accumulator separates accumulation by source_symbol.\nIf false (default), accumulations are aggregated per hedge_symbol across all source_symbols.\nControls trigger granularity for portfolios with multiple ETFs hedged to the same target instrument."
                }
              },
              "title": "수정할 헷지그룹 정보",
              "required": [
                "portfolio",
                "displayName",
                "hedgeFundCode",
                "triggerCondition"
              ]
            }
          }
        ],
        "tags": [
          "HedgeService"
        ]
      }
    },
