    "/v1/{hedge.name}": {
      "patch": {
        "summary": "Hedge 수정",
        "operationId": "HedgeService_UpdateHedge",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/hedgeHedge"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hedge.name",
            "description": "리소스 이름 (예: hedges/1)",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "hedges/[^/]+"
          },
          {
            "name": "hedge",
            "description": "수정할 헷지 정보",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int32",
                  "title": "Hedge ID",
                  "readOnly": true
                },
                "sourceFundCode": {
                  "type": "string",
                  "title": "소스(원주문) 펀드 코드"
                },
                "sourceSymbol": {
                  "type": "string",
                  "title": "소스 종목 심볼 (체결 감시 대상)"
                },
                "hedgeMethod": {
                  "$ref": "#/definitions/hedgeHedgeMethod",
                  "title": "헷지 방식"
                },
                "isActive": {
                  "type": "boolean",
                  "title": "활성화 여부"
                },
                "createTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "생성 시간",
                  "readOnly": true
                },
                "updateTime": {
                  "type": "string",
                  "format": "date-time",
                  "title": "수정 시간",
                  "readOnly": true
                },
                "execPriceType": {
                  "$ref": "#/definitions/hedgeExecPriceType",
                  "title": "헷지 주문 체결 가격 유형"
                },
                "autoAmend": {
                  "type": "boolean",
                  "title": "자동정정 활성화 여부"
                },
                "amendMethod": {
                  "$ref": "#/definitions/commonAmendMethodType",
                  "title": "자동정정 전략 유형 (auto_amend=true 일 때 유효)\n미지정(UNSPECIFIED) 시 TIMED_MARKET으로 처리됨"
                },
                "quantityPerHedge": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "헷지 1단위당 소스 종목 환산 수량 (정적 비율).\nkey: 헷지 대상 심볼.\nvalue: 헷지 1단위당 소스 수량을 십진수 문자열로 인코딩한 값 (f64 정밀도 보존).\n예) ratio=0.01 → \"100\", ratio=69.59 (leverage_future) → \"0.01437...\"",
                  "readOnly": true
                },
                "hedgeFundCode": {
                  "type": "string",
                  "title": "헷지 주문이 실행되는 펀드 코드"
                },
                "tickOffset": {
                  "type": "integer",
                  "format": "int32",
                  "description": "상대호가/호가 가격에서의 틱 오프셋 (-30 ~ +30).\n양수 = 공격적 (매수 더 비싸게 / 매도 더 싸게),\n음수 = 방어적 (매수 더 싸게 / 매도 더 비싸게).\nImmediateFill 일 때는 무시됨."
                },
                "tpCode": {
                  "$ref": "#/definitions/hedgeOrderTpCode",
                  "title": "헷지 주문 TP 코드 (호가 구분)"
                },
                "initialWaitMs": {
                  "type": "string",
                  "format": "uint64",
                  "description": "자동정정 시작 전 초기 대기 시간 (ms). auto_amend=true 일 때 유효, 등록 후 이 시간 동안 정정 보류 (0 = 즉시 정정 시작)."
                }
              },
              "title": "수정할 헷지 정보",
              "required": [
                "sourceFundCode",
                "sourceSymbol",
                "hedgeMethod",
                "hedgeFundCode"
              ]
            }
          }
        ],
        "tags": [
          "HedgeService"
        ]
      }
    },
    "/v1/{hedgeGroup.name}": {
      "patch": {
        "summary": "HedgeGroup 수정",
