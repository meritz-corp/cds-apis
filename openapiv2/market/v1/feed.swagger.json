            "type": "string",
            "format": "int64"
          },
          "title": "매도 수량 (10단계)"
        },
        "bidQuantities": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "매수 수량 (10단계)"
        },
        "midPrice": {
          "type": "string",
          "title": "중간 호가"
        },
        "midAskQuantity": {
          "type": "string",
          "format": "int64",
          "title": "중간 매도 수량"
        },
        "midBidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "중간 매수 수량"
        },
        "totalAskQuantity": {
          "type": "string",
          "format": "int64",
          "title": "총 매도 호가 수량"
        },
        "totalBidQuantity": {
          "type": "string",
          "format": "int64",
          "title": "총 매수 호가 수량"
        },
        "estPrice": {
          "type": "string",
          "title": "예상 체결가"
        },
        "estVolume": {
          "type": "string",
          "format": "int64",
          "title": "예상 체결량"
        }
      },
      "title": "주식 호가 (B601S, B601Q) - 10단계"
    },
    "feedSubscribeMarketFeedRequest": {
      "type": "object",
      "properties": {
        "symbols": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "구독 대상 ISIN 코드 목록 (예: [\"KR7252670005\", \"KR4A01630008\"])"
        },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "title": "스트리밍 시작 시각 (해당 시각 이후 데이터만 전송)"
        },
        "dataTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/feedMarketDataType"
          },
          "title": "수신할 데이터 타입 필터 (비어있으면 전체)"
        }
      },
      "title": "마켓 피드 구독 요청",
      "required": [
        "symbols",
        "startTime"
      ]
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1feedSessionId": {
      "type": "string",
      "enum": [
        "SESSION_ID_UNSPECIFIED",
        "SESSION_ID_PREVIOUS",
        "SESSION_ID_OPENING_AUCTION",
        "SESSION_ID_ONE_PRICE",
        "SESSION_ID_CLOSING_AUCTION",
        "SESSION_ID_CONTINUOUS",
        "SESSION_ID_VI_AUCTION",
        "SESSION_ID_VI_OPENING_AUCTION",
        "SESSION_ID_VI_CLOSING_AUCTION",
        "SESSION_ID_POST_MARKET",
        "SESSION_ID_AUCTION_BID",
        "SESSION_ID_AUCTION_ASK",
        "SESSION_ID_UNIT_TRADE",
        "SESSION_ID_SUSPENDED",
        "SESSION_ID_SHUTDOWN",
        "SESSION_ID_CLOSED"
      ],
      "default": "SESSION_ID_UNSPECIFIED",
      "description": "- SESSION_ID_PREVIOUS: 장개시전\n - SESSION_ID_OPENING_AUCTION: 시가단일가\n - SESSION_ID_ONE_PRICE: 단일가\n - SESSION_ID_CLOSING_AUCTION: 종가단일가\n - SESSION_ID_CONTINUOUS: 접속 (정규장)\n - SESSION_ID_VI_AUCTION: VI장중단일가\n - SESSION_ID_VI_OPENING_AUCTION: VI시가단일가\n - SESSION_ID_VI_CLOSING_AUCTION: VI종가단일가\n - SESSION_ID_POST_MARKET: 장종료후호가접수\n - SESSION_ID_AUCTION_BID: 경매매수호가 접수\n - SESSION_ID_AUCTION_ASK: 경매매도호가 접수\n - SESSION_ID_UNIT_TRADE: 단위매매\n - SESSION_ID_SUSPENDED: 거래정지\n - SESSION_ID_SHUTDOWN: SHUTDOWN\n - SESSION_ID_CLOSED: 장마감",
      "title": "세션 ID (장 상태)"
    },
    "v1feedTrade": {
      "type": "object",
      "properties": {
        "price": {
          "type": "string",
          "title": "체결 가격"
        },
        "quantity": {
          "type": "string",
          "format": "int64",
          "title": "체결 수량"
        },
        "side": {
          "$ref": "#/definitions/feedOrderSide",
          "title": "매수/매도 방향"
        },
        "cumulativeVolume": {
          "type": "string",
          "format": "int64",
          "title": "누적 거래량"
        },
        "cumulativeValue": {
          "type": "string",
          "title": "누적 거래대금"
        }
      },
      "title": "체결 (A301S, A301Q, A303S)"
    }
