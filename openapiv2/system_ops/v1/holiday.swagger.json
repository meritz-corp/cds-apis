{
  "swagger": "2.0",
  "info": {
    "title": "system_ops/v1/holiday.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "HolidayService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/businessDays:latest": {
      "get": {
        "summary": "가장 최근 영업일 조회",
        "description": "기준 날짜(미지정 시 오늘) 이전(포함)의 가장 최근 영업일을 반환합니다.\n영업일은 주말이 아니고 휴일로 등록되지 않은 날입니다.",
        "operationId": "HolidayService_GetLatestBusinessDay",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/holidayGetLatestBusinessDayResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "asOfDate",
            "description": "기준 날짜 (YYYYMMDD). 미지정 시 오늘 날짜 기준.\n이 날짜를 포함한 이전의 가장 최근 영업일을 반환합니다.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "HolidayService"
        ]
      }
    },
    "/v1/holidays": {
      "get": {
        "summary": "휴일 목록 조회",
        "operationId": "HolidayService_ListHolidays",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/holidayListHolidaysResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "pageSize",
            "description": "페이지 크기 (optional)",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageToken",
            "description": "페이지 토큰 (optional, for pagination)",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "filter",
            "description": "필터링 조건 (optional, AIP-160)\n\nAvailable Fields:\n* date - 날짜 (YYYYMMDD, 부분 일치로 연/월 조회 가능)\n* display_name - 휴일명 (문자열, 부분 일치)\n* holiday_type - 휴일 유형 (HOLIDAY_TYPE_PUBLIC, HOLIDAY_TYPE_TEMPORARY, HOLIDAY_TYPE_MARKET_CLOSED)\n\nOperators:\n* = : 일치\n* != : 불일치\n* : : 포함 (문자열 부분 일치)\n\nExamples:\n* date:\"2026\"\n* date:\"202601\"\n* holiday_type=HOLIDAY_TYPE_PUBLIC\n* holiday_type=HOLIDAY_TYPE_MARKET_CLOSED AND date:\"2026\"",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "HolidayService"
        ]
      },
      "post": {
        "summary": "휴일 등록",
        "operationId": "HolidayService_CreateHoliday",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/holidayHoliday"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "holiday",
            "description": "등록할 휴일",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/holidayHoliday",
              "required": [
                "holiday"
              ]
            }
          }
        ],
        "tags": [
          "HolidayService"
        ]
      }
    },
    "/v1/holidays:byDate": {
      "get": {
        "summary": "날짜로 휴일 조회",
        "description": "해당 날짜가 휴일이면 Holiday를 반환하고, 휴일이 아니면 NOT_FOUND를 반환합니다.",
        "operationId": "HolidayService_GetHolidayByDate",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/holidayHoliday"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "date",
            "description": "조회할 날짜 (YYYYMMDD)",
            "in": "query",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "HolidayService"
        ]
      }
    },
    "/v1/holidays:checkToday": {
      "get": {
        "summary": "오늘 휴일 여부 확인",
        "description": "서버 기준 오늘 날짜가 휴일인지 여부를 반환합니다.\n특정 날짜를 확인하려면 GetHolidayByDate를 사용하세요.",
        "operationId": "HolidayService_CheckHoliday",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/holidayCheckHolidayResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "HolidayService"
        ]
      }
    },
    "/v1/{holiday}": {
      "delete": {
        "summary": "휴일 삭제",
        "operationId": "HolidayService_DeleteHoliday",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "holiday",
            "description": "리소스 이름 (holidays/{date})",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": "holidays/[^/]+"
          }
        ],
        "tags": [
          "HolidayService"
        ]
      }
    }
  },
  "definitions": {
    "holidayCheckHolidayResponse": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "title": "확인한 날짜 (서버 기준 오늘, YYYYMMDD)"
        },
        "isHoliday": {
          "type": "boolean",
          "title": "휴일 여부"
        },
        "holiday": {
          "$ref": "#/definitions/holidayHoliday",
          "title": "휴일 상세 정보 (is_holiday=true 인 경우에만 채워짐)"
        }
      }
    },
    "holidayGetLatestBusinessDayResponse": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "title": "가장 최근 영업일 (YYYYMMDD)"
        }
      }
    },
    "holidayHoliday": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "리소스 이름 (holidays/{date})"
        },
        "date": {
          "type": "string",
          "title": "날짜 (YYYYMMDD) - 고유 식별자"
        },
        "displayName": {
          "type": "string",
          "title": "휴일명 (예: \"신정\", \"설날\", \"임시공휴일\")"
        },
        "holidayType": {
          "$ref": "#/definitions/holidayHolidayType",
          "title": "휴일 유형"
        },
        "description": {
          "type": "string",
          "title": "비고 (optional)"
        },
        "createTime": {
          "type": "string",
          "format": "date-time",
          "title": "생성 시간",
          "readOnly": true
        },
        "updateTime": {
          "type": "string",
          "format": "date-time",
          "title": "수정 시간",
          "readOnly": true
        }
      },
      "title": "휴일 - 시장이 휴장하는 날",
      "required": [
        "date",
        "displayName"
      ]
    },
    "holidayHolidayType": {
      "type": "string",
      "enum": [
        "HOLIDAY_TYPE_UNSPECIFIED",
        "HOLIDAY_TYPE_PUBLIC",
        "HOLIDAY_TYPE_TEMPORARY",
        "HOLIDAY_TYPE_MARKET_CLOSED"
      ],
      "default": "HOLIDAY_TYPE_UNSPECIFIED",
      "description": "- HOLIDAY_TYPE_PUBLIC: 법정 공휴일\n - HOLIDAY_TYPE_TEMPORARY: 임시 공휴일\n - HOLIDAY_TYPE_MARKET_CLOSED: 거래소 휴장일 (공휴일은 아니나 시장이 열리지 않는 날)",
      "title": "휴일 유형"
    },
    "holidayListHolidaysResponse": {
      "type": "object",
      "properties": {
        "holidays": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/holidayHoliday"
          },
          "title": "휴일 목록"
        },
        "nextPageToken": {
          "type": "string",
          "title": "다음 페이지 토큰"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
